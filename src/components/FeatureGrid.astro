---
import { features, featureCategories, type Feature } from "~/data/features";
import MotionReveal from "~/components/MotionReveal.astro";

interface Props {
  /** Limit to a single category (omit to render all three). */
  category?: (typeof featureCategories)[number];
  /** Max number of features to render — handy for the Home page teaser. */
  limit?: number;
  /** When true, render the category headings inline (used on /features). */
  withHeadings?: boolean;
}

const { category, limit, withHeadings = false } = Astro.props;

const filterCat = (f: Feature): boolean =>
  !category ? true : f.category === category;

const visible = features.filter(filterCat);
const cards = limit ? visible.slice(0, limit) : visible;

const grouped: Record<string, typeof features> = {};
for (const cat of featureCategories) {
  const list = cards.filter((c) => c.category === cat);
  if (list.length) grouped[cat] = list;
}

const tierClass = (tier: Feature["tier"]) => {
  switch (tier) {
    case "Free":
      return "bg-ok/12 text-ok";
    case "Pro":
      return "bg-accent/14 text-accent";
  }
};
---

{
  withHeadings
    ? Object.entries(grouped).map(([cat, list]) => (
        <div class="mb-16 last:mb-0">
          <h3 class="mb-1 text-lg font-semibold tracking-tight text-text">
            {cat}
          </h3>
          <p class="mb-6 text-sm text-text-tertiary">
            {cat === "Scale" &&
              "Visibility and monitor reach across every TrueNAS you operate."}
            {cat === "Advanced Control" &&
              "Lifecycle and configuration mutation, gated by Control Mode and biometric confirmation."}
            {cat === "Operator Productivity" &&
              "Everyday leverage — debugging, history, sync, and live insight."}
          </p>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {list.map((f, i) => (
              <MotionReveal delay={i * 30}>
                <article class="feature-card group h-full rounded-lg border border-stroke-soft bg-surface p-5">
                  <header class="mb-2 flex items-start justify-between gap-3">
                    <h4 class="text-[15px] font-semibold text-text">
                      {f.name}
                    </h4>
                    <span
                      class:list={[
                        "shrink-0 rounded-full px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider",
                        tierClass(f.tier),
                      ]}
                    >
                      {f.tier}
                    </span>
                  </header>
                  <p class="text-sm leading-relaxed text-text-secondary">
                    {f.description}
                  </p>
                </article>
              </MotionReveal>
            ))}
          </div>
        </div>
      ))
    : (
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {cards.map((f, i) => (
          <MotionReveal delay={i * 30}>
            <article class="group h-full rounded-lg border border-stroke-soft bg-surface p-5">
              <header class="mb-2 flex items-start justify-between gap-3">
                <h4 class="text-[15px] font-semibold text-text">
                  {f.name}
                </h4>
                <span
                  class:list={[
                    "shrink-0 rounded-full px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider",
                    tierClass(f.tier),
                  ]}
                >
                  {f.tier}
                </span>
              </header>
              <p class="text-sm leading-relaxed text-text-secondary">
                {f.description}
              </p>
            </article>
          </MotionReveal>
        ))}
      </div>
    )
}

<style>
  .feature-card {
    position: relative;
    transition: border-color 0.28s ease, background-color 0.28s ease, transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
  }
  /* Subtle top-edge highlight — glass refraction effect */
  .feature-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, oklch(1 0 0 / 0.12) 40%, oklch(1 0 0 / 0.12) 60%, transparent 100%);
    pointer-events: none;
  }
  /* Gradient border on hover — lights up from the top-left */
  .feature-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      135deg,
      oklch(0.62 0.16 235 / 0) 0%,
      oklch(0.62 0.16 235 / 0.35) 45%,
      oklch(0.66 0.14 150 / 0.20) 55%,
      oklch(0.66 0.14 150 / 0) 100%
    );
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .feature-card:hover {
    border-color: oklch(1 0 0 / 0.10);
    background-color: oklch(from var(--color-surface) l c h / 0.70);
    transform: translateY(-2px);
  }
  .feature-card:hover::after {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .feature-card:hover { transform: none; }
  }
</style>
