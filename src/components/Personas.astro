---
/**
 * "Is this for me?" personas strip — three short cards with a one-line
 * scenario each. Helps Free-curious visitors self-identify before
 * scrolling further.
 *
 * Personas pulled from APP_STORE_METADATA.md description audience
 * ("sysadmins, operators, and homelab users") and MONETIZATION.md
 * §2 Target Audience. No invented use cases.
 */

interface Persona {
  /** Short label rendered as a tag. */
  tag: string;
  /** Headline framed as the user's situation. */
  headline: string;
  /** One-line value statement. */
  body: string;
  /** Inline icon. */
  icon: "wrench" | "home" | "phone";
}

const personas: Persona[] = [
  {
    tag: "Sysadmin",
    headline: "On-call, two screens, one phone.",
    body:
      "Check health, alerts, and jobs quickly, then use guarded actions only when something needs intervention.",
    icon: "wrench",
  },
  {
    tag: "Homelabber",
    headline: "Your basement rack, in your pocket.",
    body:
      "Keep pool health, disk status, alerts, and a Home Screen widget close without paying before the app is useful.",
    icon: "home",
  },
  {
    tag: "MSP / on-call",
    headline: "When a customer pings at 22:00.",
    body:
      "Use Pro when you need deeper fleet visibility, longer history, Server Console access, and operator controls.",
    icon: "phone",
  },
];
---

<div class="personas-grid">
  {
    personas.map((p, i) => (
      <article class="persona reveal-init" data-reveal-delay={i * 80}>
        <div class="persona-icon" aria-hidden="true">
          {p.icon === "wrench" && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <path d="M14.7 6.3a4 4 0 0 1 5 5l-3-1-1.5 1.5 1 3-3 1-3-3-6 6a2.1 2.1 0 1 1-3-3l6-6-3-3 1-3 3 1L13 3.3l-1 3 2.7 0z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
            </svg>
          )}
          {p.icon === "home" && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <path d="M3 11l9-7 9 7v9a2 2 0 0 1-2 2h-4v-6h-6v6H5a2 2 0 0 1-2-2v-9z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
            </svg>
          )}
          {p.icon === "phone" && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 6 6L15 14l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
            </svg>
          )}
        </div>
        <span class="persona-tag">{p.tag}</span>
        <h3 class="persona-headline">{p.headline}</h3>
        <p class="persona-body">{p.body}</p>
      </article>
    ))
  }
</div>

<style>
  .personas-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .personas-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .persona {
    position: relative;
    padding: 1.75rem 1.5rem;
    border-radius: 1rem;
    border: 1px solid var(--color-stroke-soft);
    background: oklch(from var(--color-surface) l c h / 0.55);
    transition: border-color 0.32s ease, transform 0.32s cubic-bezier(0.22, 1, 0.36, 1), background-color 0.32s ease;
    overflow: hidden;
  }
  .persona::after {
    /* Subtle accent rail down the left edge — matches iOS row treatment */
    content: "";
    position: absolute;
    inset-block: 1.75rem;
    inset-inline-start: 0;
    width: 2px;
    border-radius: 1px;
    background: linear-gradient(180deg, var(--color-accent), var(--color-accent-secondary));
    opacity: 0.5;
    transition: opacity 0.32s ease;
  }
  .persona:hover {
    border-color: var(--color-stroke-strong);
    background: oklch(from var(--color-surface) l c h / 0.8);
    transform: translateY(-2px);
  }
  .persona:hover::after { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    .persona:hover { transform: none; }
  }

  .persona-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 0.625rem;
    margin-bottom: 1rem;
    background: oklch(from var(--color-accent) l c h / 0.10);
    color: var(--color-accent);
    box-shadow: inset 0 0 0 1px oklch(from var(--color-accent) l c h / 0.18);
  }
  .persona-tag {
    display: inline-block;
    margin-bottom: 0.5rem;
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
    background: oklch(from var(--color-accent) l c h / 0.12);
    color: var(--color-accent);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .persona-headline {
    margin: 0 0 0.5rem 0;
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-text);
    line-height: 1.3;
  }
  .persona-body {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }
</style>
