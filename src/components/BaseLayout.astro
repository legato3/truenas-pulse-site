---
import "~/styles/global.css";
import { site } from "~/data/site";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";

interface FrontmatterShape {
  title?: string;
  description?: string;
  ogImage?: string;
  prose?: boolean;
  noindex?: boolean;
}

interface Props extends FrontmatterShape {
  /**
   * Astro automatically supplies frontmatter from MDX files via this prop
   * (NOT as individual props). We merge it back so MDX pages and .astro
   * callers behave identically.
   */
  frontmatter?: FrontmatterShape;
}

// Merge: explicit props win over frontmatter; frontmatter wins over defaults.
const fm = Astro.props.frontmatter ?? {};
const merged: Required<FrontmatterShape> = {
  title: Astro.props.title ?? fm.title ?? "",
  description: Astro.props.description ?? fm.description ?? site.tagline,
  ogImage: Astro.props.ogImage ?? fm.ogImage ?? "/og-image.png",
  prose: Astro.props.prose ?? fm.prose ?? false,
  noindex: Astro.props.noindex ?? fm.noindex ?? false,
};
const { title, description, ogImage, prose, noindex } = merged;

const fullTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.subtitle}`;
const canonical = new URL(Astro.url.pathname, site.origin).toString();
const og = new URL(ogImage, site.origin).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#0a0a0b" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={canonical} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={og} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={og} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Structured data — MobileApplication rich result -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "MobileApplication",
        name: site.name,
        applicationCategory: "UtilitiesApplication",
        applicationSubCategory: "Network Monitoring",
        operatingSystem: `iOS ${site.minimumOsVersion}`,
        softwareVersion: site.latestVersion,
        url: site.origin,
        downloadUrl: site.appStoreUrl,
        author: {
          "@type": "Person",
          name: "Christophe Cornelis",
        },
        featureList: [
          "Live TrueNAS SCALE monitoring",
          "Pool and storage health dashboard",
          "Smart proactive alerts",
          "Control Mode admin actions with biometric auth",
          "Home Screen widget",
          "Dynamic Island and Live Activities",
          "iCloud sync across devices",
          "Self-signed TLS certificate pinning",
          "Optional Cloud Push Relay for background alert notifications",
          "Demo mode with sample data",
        ].join(", "),
        screenshot: [
          `${site.origin}/screenshots/01-dashboard.webp`,
          `${site.origin}/screenshots/02-storage.webp`,
          `${site.origin}/screenshots/03-sharing.webp`,
          `${site.origin}/screenshots/04-workloads.webp`,
          `${site.origin}/screenshots/05-fleet.webp`,
          `${site.origin}/screenshots/06-reporting.webp`,
          `${site.origin}/screenshots/07-widget.webp`,
        ],
        offers: [
          {
            "@type": "Offer",
            price: "0",
            priceCurrency: "USD",
            description: "Free tier — live monitoring, alerts, storage health, 2 servers, Home Screen widget.",
          },
          {
            "@type": "Offer",
            price: "9.99",
            priceCurrency: "USD",
            description: "Pro — one-time lifetime purchase. Fleet view, terminal, 30-day history, iCloud sync, 8 servers.",
          },
        ],
      })}
    />

    {/*
      Self-hosted Plausible Analytics — served directly from analytics.phobos-cc.be
      (Plausible CE on LXC 132). Cookieless, no personal data, no cross-site
      tracking, GDPR-compliant. Used only for aggregate site traffic; the iOS app
      itself has no analytics or telemetry whatsoever.
    */}
    <script
      is:inline
      defer
      data-domain="pulse.phobos-cc.be"
      data-api="https://analytics.phobos-cc.be/api/event"
      src="https://analytics.phobos-cc.be/js/script.js"
    ></script>
  </head>
  <body class="font-sans text-text antialiased">
    <a
      href="#content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-50 focus:rounded-md focus:bg-surface focus:px-3 focus:py-2 focus:text-sm focus:outline focus:outline-2 focus:outline-accent"
    >
      Skip to content
    </a>

    <!-- Full-page ambient layer: grid + orbs, fixed behind all content on every page -->
    <div aria-hidden="true" class="page-ambient">
      <div class="page-grid"></div>
      <span class="page-orb page-orb-1"></span>
      <span class="page-orb page-orb-2"></span>
      <span class="page-orb page-orb-3"></span>
    </div>

    <Header />

    <main id="content" class:list={[prose ? "prose-page" : ""]}>
      <slot />
    </main>

    <Footer />

    <style>
      .page-ambient {
        position: fixed;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: 0;
        /* Scroll-driven cycle: hue shifts gently as you scroll, one full cycle top→bottom */
        animation: ambient-scroll-cycle linear both;
        animation-timeline: scroll(root);
      }

      @keyframes ambient-scroll-cycle {
        /* Strictly cool band: blue → cyan side and back. ±8deg from base
           keeps every frame inside hue 220–250 — never crosses into violet. */
        0%   { filter: hue-rotate(0deg)  brightness(1.00); }
        30%  { filter: hue-rotate(-8deg) brightness(0.97); }
        65%  { filter: hue-rotate(8deg)  brightness(1.02); }
        100% { filter: hue-rotate(0deg)  brightness(1.00); }
      }

      /* Grid — 96px cells, very subtle lines so they don't overpower content */
      .page-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(to right,  oklch(1 0 0 / 0.032) 1px, transparent 1px),
          linear-gradient(to bottom, oklch(1 0 0 / 0.032) 1px, transparent 1px);
        background-size: 96px 96px;
        /* Fade grid out toward the bottom so it doesn't look like wallpaper */
        mask-image: linear-gradient(180deg, black 0%, black 40%, oklch(0 0 0 / 0.4) 100%);
        -webkit-mask-image: linear-gradient(180deg, black 0%, black 40%, oklch(0 0 0 / 0.4) 100%);
      }

      /* Global orbs — very subtle, just enough to give depth to inner pages.
         The hero has its own stronger focused orbs; these should not compete. */
      .page-orb {
        position: absolute;
        border-radius: 50%;
        will-change: transform;
      }
      /* Distant top-left ambient — soft, not a spotlight */
      .page-orb-1 {
        top: -10%;
        left: -5%;
        width: 900px;
        height: 900px;
        opacity: 0.13;
        filter: blur(160px);
        background: radial-gradient(circle, oklch(0.65 0.14 235 / 0.8), transparent 65%);
        animation: drift-a 30s ease-in-out infinite;
      }
      /* Right-side very faint fill */
      .page-orb-2 {
        top: 30%;
        right: -10%;
        width: 700px;
        height: 700px;
        opacity: 0.08;
        filter: blur(150px);
        background: radial-gradient(circle, oklch(0.58 0.11 235 / 0.7), transparent 65%);
        animation: drift-b 38s ease-in-out infinite;
      }
      /* Bottom glow — barely visible, keeps deep pages from going flat black */
      .page-orb-3 {
        bottom: -20%;
        left: 30%;
        width: 800px;
        height: 800px;
        opacity: 0.07;
        filter: blur(160px);
        background: radial-gradient(circle, oklch(0.55 0.09 235 / 0.6), transparent 65%);
        animation: drift-c 44s ease-in-out infinite;
      }
      @keyframes drift-a {
        0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
        50%      { transform: translate3d(30px, 20px, 0) scale(1.04); }
      }
      @keyframes drift-b {
        0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
        50%      { transform: translate3d(-20px, 30px, 0) scale(1.05); }
      }
      @keyframes drift-c {
        0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
        50%      { transform: translate3d(20px, -30px, 0) scale(1.04); }
      }
      @media (prefers-reduced-motion: reduce) {
        .page-orb { animation: none !important; }
      }

      .prose-page {
        max-width: 56rem;
        margin: 0 auto;
        padding-block: clamp(2.5rem, 6vw, 5rem);
        padding-inline: clamp(1.25rem, 4vw, 2.5rem);
      }
      .prose-page :global(h1) {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        margin-block: 0 1.25rem;
      }
      .prose-page :global(h2) {
        font-size: 1.375rem;
        font-weight: 600;
        margin-block: 2.5rem 0.75rem;
        letter-spacing: -0.01em;
      }
      .prose-page :global(h3) {
        font-size: 1.125rem;
        font-weight: 600;
        margin-block: 1.75rem 0.5rem;
      }
      .prose-page :global(p),
      .prose-page :global(li) {
        line-height: 1.7;
        color: var(--color-text-secondary);
      }
      .prose-page :global(p) { margin-block: 0 1rem; }
      .prose-page :global(ul), .prose-page :global(ol) { padding-inline-start: 1.5rem; margin-block: 0 1rem; }
      .prose-page :global(li) { margin-block: 0 0.5rem; }
      .prose-page :global(a) {
        color: var(--color-accent);
        text-underline-offset: 3px;
      }
      .prose-page :global(a:hover) {
        color: var(--color-accent-hover);
      }
      .prose-page :global(code) {
        font-family: var(--font-mono);
        font-size: 0.875em;
        background: var(--color-surface);
        padding: 0.15em 0.4em;
        border-radius: var(--radius-xs);
      }
      .prose-page :global(blockquote) {
        border-inline-start: 2px solid var(--color-stroke-strong);
        padding-inline-start: 1rem;
        color: var(--color-text-secondary);
        font-style: italic;
        margin-block: 1.25rem;
      }
      .prose-page :global(hr) {
        border: 0;
        border-top: 1px solid var(--color-stroke-soft);
        margin-block: 2.5rem;
      }
    </style>
  </body>
</html>
