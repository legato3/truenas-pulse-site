---
interface Props {
  /** Optional eyebrow label above the heading. */
  eyebrow?: string;
  heading?: string;
  lede?: string;
  /** Heading element for the section title. Use h1 for page-level headings. */
  headingLevel?: "h1" | "h2";
  /** Maximum content width: "narrow" for prose, "wide" for full-bleed. */
  width?: "narrow" | "wide";
  /** Tighten vertical padding for stacked sections. */
  tight?: boolean;
  id?: string;
  className?: string;
}

const {
  eyebrow,
  heading,
  lede,
  headingLevel = "h2",
  width = "wide",
  tight = false,
  id,
  className,
} = Astro.props;

const HeadingTag = headingLevel;
---

<section
  id={id}
  class:list={[
    "px-5",
    tight ? "py-12 sm:py-16" : "py-16 sm:py-24 lg:py-32",
    className,
  ]}
>
  <div
    class:list={[
      "mx-auto",
      width === "narrow" ? "max-w-3xl" : "max-w-6xl",
    ]}
  >
    {
      (eyebrow || heading || lede) && (
        <div class="mb-10 sm:mb-14">
          {eyebrow && (
            <p class="mb-3 text-xs font-medium uppercase tracking-[0.18em] text-text-tertiary">
              {eyebrow}
            </p>
          )}
          {heading && (
            <HeadingTag class="text-balance text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold leading-tight tracking-tight text-text">
              {heading}
            </HeadingTag>
          )}
          {lede && (
            <p class="mt-4 max-w-2xl text-pretty text-base leading-relaxed text-text-secondary sm:text-lg">
              {lede}
            </p>
          )}
        </div>
      )
    }
    <slot />
  </div>
</section>
