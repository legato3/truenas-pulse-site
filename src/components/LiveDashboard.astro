---
/**
 * LiveDashboard.astro
 * CSS-only animated mockup of the TrueNAS Pulse app dashboard.
 * Uses the exact design tokens from Design.swift — no external assets, no JS.
 * Renders inside DeviceFrame (synthetic content, Dynamic Island handled by parent).
 *
 * Animation narrative:
 *   0–2 s   → healthy state visible
 *   2–3 s   → "Pool degraded" toast slides in from top
 *   3–9 s   → toast holds; user would reach for their phone
 *   9–10 s  → toast fades out
 *   10–14 s → healthy state, then cycle repeats
 */
---

<div class="ld" aria-hidden="true">
  <!-- iOS status bar -->
  <div class="ld-statusbar">
    <span class="ld-time">9:41</span>
    <div class="ld-status-icons">
      <!-- Signal bars -->
      <svg width="17" height="11" viewBox="0 0 17 11" fill="currentColor">
        <rect x="0"    y="5"  width="3" height="6" rx="1" opacity=".35"/>
        <rect x="4.5"  y="3.5" width="3" height="7.5" rx="1" opacity=".55"/>
        <rect x="9"   y="2"  width="3" height="9"  rx="1" opacity=".8"/>
        <rect x="13.5" y="0"  width="3" height="11" rx="1"/>
      </svg>
      <!-- Wi-Fi -->
      <svg width="15" height="11" viewBox="0 0 15 11" fill="currentColor">
        <path d="M7.5 2.2C5 2.2 2.8 3.2 1.2 4.8L0 3.6C1.9 1.6 4.6.4 7.5.4s5.6 1.2 7.5 3.2l-1.2 1.2C12.2 3.2 10 2.2 7.5 2.2z" opacity=".45"/>
        <path d="M7.5 5c-1.5 0-2.9.6-3.9 1.6L2.4 5.4C3.7 4 5.5 3.2 7.5 3.2s3.8.8 5.1 2.2l-1.2 1.2C10.4 5.6 9 5 7.5 5z" opacity=".7"/>
        <path d="M7.5 7.8c-.8 0-1.5.3-2 .8L4.3 7.4C5.1 6.6 6.3 6.1 7.5 6.1s2.4.5 3.2 1.3l-1.2 1.2c-.5-.5-1.2-.8-2-.8z"/>
        <circle cx="7.5" cy="10.2" r="1"/>
      </svg>
      <!-- Battery -->
      <svg width="25" height="11" viewBox="0 0 25 11" fill="none">
        <rect x=".5" y=".5" width="21" height="10" rx="2.5" stroke="currentColor" stroke-opacity=".35"/>
        <rect x="22.5" y="3" width="1.5" height="5" rx=".75" fill="currentColor" fill-opacity=".4"/>
        <rect x="1.5" y="1.5" width="17" height="8" rx="1.5" fill="currentColor"/>
      </svg>
    </div>
  </div>

  <!-- App navigation bar -->
  <div class="ld-nav">
    <span class="ld-nav-title">Servers</span>
    <span class="ld-nav-add">+</span>
  </div>

  <!-- Content list -->
  <div class="ld-content">

    <!-- Primary server card -->
    <div class="ld-card">
      <div class="ld-card-head">
        <div>
          <div class="ld-server-name">GOLDEYE</div>
          <div class="ld-server-sub">TrueNAS SCALE 25.10</div>
        </div>
        <span class="ld-pill ld-pill-ok">HEALTHY</span>
      </div>

      <div class="ld-sep"></div>

      <!-- Storage -->
      <div class="ld-row">
        <span class="ld-label">Storage</span>
        <span class="ld-mono ld-dim">22.3 / 33.2 TB</span>
      </div>
      <div class="ld-bar"><div class="ld-bar-fill" style="width:67.2%"></div></div>

      <div class="ld-sep"></div>

      <!-- Pool -->
      <div class="ld-row">
        <div class="ld-row-l">
          <span class="ld-dot ld-dot-ok"></span>
          <span class="ld-label">data</span>
        </div>
        <span class="ld-mono ld-ok">ONLINE</span>
      </div>

      <div class="ld-sep"></div>

      <!-- System metrics grid -->
      <div class="ld-sys">
        <div class="ld-sys-item">
          <span class="ld-sys-lbl">CPU</span>
          <!-- CSS-only value cycling: 3 spans, each visible 1/3 of the time -->
          <div class="ld-cpu">
            <span class="ld-mono ld-sys-val ld-c1">4%</span>
            <span class="ld-mono ld-sys-val ld-c2">7%</span>
            <span class="ld-mono ld-sys-val ld-c3">3%</span>
          </div>
        </div>
        <div class="ld-sys-item">
          <span class="ld-sys-lbl">Memory</span>
          <span class="ld-mono ld-sys-val">78%</span>
        </div>
        <div class="ld-sys-item">
          <span class="ld-sys-lbl">Uptime</span>
          <span class="ld-mono ld-sys-val">14d 6h</span>
        </div>
      </div>

      <div class="ld-sep"></div>

      <!-- Network -->
      <div class="ld-row">
        <span class="ld-label">Network</span>
        <span class="ld-mono ld-dim">↓ 24 MB/s &nbsp;↑ 0.4 MB/s</span>
      </div>

      <div class="ld-sep"></div>

      <!-- Disk temps -->
      <div class="ld-row">
        <span class="ld-label">Disk temps</span>
        <span class="ld-mono ld-ok">38° 41° 39° 37°</span>
      </div>
    </div>

    <!-- Secondary server card -->
    <div class="ld-card ld-card-dim">
      <div class="ld-card-head">
        <div>
          <div class="ld-server-name">ARCHIVE-01</div>
          <div class="ld-server-sub">TrueNAS SCALE 25.10</div>
        </div>
        <span class="ld-pill ld-pill-ok">HEALTHY</span>
      </div>
      <div class="ld-sep"></div>
      <div class="ld-row">
        <span class="ld-label">Storage</span>
        <span class="ld-mono ld-dim">84.1 / 108 TB</span>
      </div>
      <div class="ld-bar"><div class="ld-bar-fill" style="width:77.9%"></div></div>
    </div>

  </div><!-- /.ld-content -->

  <!--
    Toast notification — slides in from top after 2 s, holds 6 s, fades out.
    Total cycle: 14 s repeating. CSS-only, no JS.
  -->
  <div class="ld-toast">
    <div class="ld-toast-icon">
      <!-- Warning triangle in amber -->
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
        <rect width="28" height="28" rx="6" fill="oklch(0.72 0.14 60 / 0.18)"/>
        <path d="M14 4L25.5 23H2.5L14 4z" fill="oklch(0.72 0.14 60 / 0.22)" stroke="oklch(0.72 0.14 60)" stroke-width="1.5" stroke-linejoin="round"/>
        <path d="M14 11v5" stroke="oklch(0.72 0.14 60)" stroke-width="2" stroke-linecap="round"/>
        <circle cx="14" cy="19.5" r="1" fill="oklch(0.72 0.14 60)"/>
      </svg>
    </div>
    <div class="ld-toast-text">
      <div class="ld-toast-app">TrueNAS Pulse</div>
      <div class="ld-toast-msg">Pool degraded &middot; GOLDEYE</div>
    </div>
  </div>

</div><!-- /.ld -->

<style>
  /* ── Root ────────────────────────────────────────────────────── */
  .ld {
    position: relative;
    width: 100%;
    height: 100%;
    background: oklch(0.13 0 0);
    color: oklch(1 0 0 / 0.96);
    font-family: var(--font-sans);
    font-size: clamp(7px, 2vw, 10px); /* scales with viewport, frame is 32vw */
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── Status bar ──────────────────────────────────────────────── */
  .ld-statusbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.4em 1.6em 0.4em;
    flex-shrink: 0;
  }
  .ld-time {
    font-size: 1.25em;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .ld-status-icons {
    display: flex;
    align-items: center;
    gap: 5px;
    color: oklch(1 0 0 / 0.9);
  }

  /* ── Nav bar ─────────────────────────────────────────────────── */
  .ld-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.3em 1.2em 0.7em;
    flex-shrink: 0;
  }
  .ld-nav-title {
    font-size: 2.2em;
    font-weight: 700;
    letter-spacing: -0.025em;
  }
  .ld-nav-add {
    font-size: 2.4em;
    font-weight: 300;
    line-height: 1;
    color: oklch(0.62 0.16 235);
  }

  /* ── Scrollable list ─────────────────────────────────────────── */
  .ld-content {
    flex: 1;
    padding: 0 0.9em 0.9em;
    display: flex;
    flex-direction: column;
    gap: 0.7em;
    overflow: hidden;
  }

  /* ── Cards ───────────────────────────────────────────────────── */
  .ld-card {
    background: oklch(0.20 0 0);
    border: 1px solid oklch(1 0 0 / 0.07);
    border-radius: 1.4em;
    padding: 0.9em 1.1em;
    display: flex;
    flex-direction: column;
    gap: 0.65em;
  }
  .ld-card-dim { opacity: 0.42; }

  .ld-card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5em;
  }

  /* ── Server identity ─────────────────────────────────────────── */
  .ld-server-name {
    font-family: var(--font-mono);
    font-size: 1.25em;
    font-weight: 600;
    letter-spacing: 0.05em;
  }
  .ld-server-sub {
    font-size: 0.9em;
    color: oklch(0.62 0.01 250 / 0.62);
    margin-top: 0.15em;
  }

  /* ── Status pill ─────────────────────────────────────────────── */
  .ld-pill {
    font-family: var(--font-mono);
    font-size: 0.78em;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 0.25em 0.7em;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .ld-pill-ok {
    background: oklch(0.66 0.14 150 / 0.14);
    color: oklch(0.66 0.14 150);
  }

  /* ── Separator ───────────────────────────────────────────────── */
  .ld-sep {
    height: 1px;
    background: oklch(1 0 0 / 0.06);
    margin: 0 -1.1em;
  }

  /* ── Generic row ─────────────────────────────────────────────── */
  .ld-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.4em;
  }
  .ld-row-l {
    display: flex;
    align-items: center;
    gap: 0.55em;
  }
  .ld-label {
    font-size: 1em;
    color: oklch(0.74 0.01 250 / 0.86);
  }

  /* ── Monospace values ────────────────────────────────────────── */
  .ld-mono {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 1em;
  }
  .ld-ok  { color: oklch(0.66 0.14 150); }
  .ld-dim { color: oklch(1 0 0 / 0.7); }

  /* ── Progress bar ────────────────────────────────────────────── */
  .ld-bar {
    height: 3px;
    background: oklch(1 0 0 / 0.08);
    border-radius: 999px;
    overflow: hidden;
  }
  .ld-bar-fill {
    height: 100%;
    background: oklch(0.62 0.16 235);
    border-radius: 999px;
  }

  /* ── Status dot ──────────────────────────────────────────────── */
  .ld-dot {
    width: 0.55em;
    height: 0.55em;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .ld-dot-ok {
    background: oklch(0.66 0.14 150);
    box-shadow: 0 0 5px oklch(0.66 0.14 150 / 0.65);
  }

  /* ── System metrics 3-col grid ───────────────────────────────── */
  .ld-sys {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.3em;
  }
  .ld-sys-item {
    display: flex;
    flex-direction: column;
    gap: 0.15em;
  }
  .ld-sys-lbl {
    font-size: 0.88em;
    color: oklch(0.62 0.01 250 / 0.62);
  }
  .ld-sys-val {
    font-size: 1.15em;
    font-weight: 500;
    color: oklch(1 0 0 / 0.88);
  }

  /* ── CPU value cycling ───────────────────────────────────────── */
  .ld-cpu {
    position: relative;
    height: 1.4em;
  }
  .ld-cpu span {
    position: absolute;
    left: 0;
    top: 0;
  }
  /* 3 values, each visible for 1/3 of a 9 s cycle */
  .ld-c1 { animation: cpu-tick 9s 0s infinite; }
  .ld-c2 { animation: cpu-tick 9s -3s infinite; opacity: 0; }
  .ld-c3 { animation: cpu-tick 9s -6s infinite; opacity: 0; }

  @keyframes cpu-tick {
    0%,  26% { opacity: 1; }
    34%, 100% { opacity: 0; }
  }

  /* ── Toast notification ──────────────────────────────────────── */
  .ld-toast {
    position: absolute;
    top: 0.6em;
    left: 0.5em;
    right: 0.5em;
    background: oklch(0.245 0 0);
    border: 1px solid oklch(1 0 0 / 0.11);
    border-radius: 1.4em;
    padding: 0.7em 0.9em;
    display: flex;
    align-items: center;
    gap: 0.75em;
    box-shadow:
      0 8px 24px oklch(0 0 0 / 0.55),
      0 0 0 1px oklch(0 0 0 / 0.3);

    /* hidden by default; animation brings it in */
    opacity: 0;
    transform: translateY(-110%);
    animation: toast-life 14s 2s infinite;
  }
  .ld-toast-icon { flex-shrink: 0; }
  .ld-toast-app {
    font-size: 0.82em;
    color: oklch(0.62 0.01 250 / 0.62);
    margin-bottom: 0.1em;
  }
  .ld-toast-msg {
    font-size: 0.97em;
    font-weight: 500;
    color: oklch(1 0 0 / 0.92);
  }

  /*
    Cycle: 14 s total
      0–7%   (0–1 s):  slide in
      7–64%  (1–9 s):  hold
      64–79% (9–11 s): fade out
      79–100% (11–14 s): hidden, wait
  */
  @keyframes toast-life {
    0%        { opacity: 0; transform: translateY(-110%); }
    7%        { opacity: 1; transform: translateY(0);    }
    64%       { opacity: 1; transform: translateY(0);    }
    79%       { opacity: 0; transform: translateY(-18%); }
    100%      { opacity: 0; transform: translateY(-110%); }
  }

  /* ── Reduced motion ──────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .ld-c1 { animation: none; opacity: 1; }
    .ld-c2, .ld-c3 { display: none; }
    .ld-toast { animation: none; opacity: 1; transform: translateY(0); }
  }
</style>
