---
/**
 * Animated security architecture diagram.
 *
 * Shows: iPhone (Keychain + Strict TLS) ↔ direct connection ↔ TrueNAS SCALE.
 * No middle servers, no in-app analytics, no developer-operated backend.
 *
 * Pure SVG + CSS — no JS, no runtime cost. Animation is a slow dotted-line
 * pulse to convey "data flowing exclusively between your phone and your
 * server", matching the calm/infrastructure-grade tone.
 */
---

<div class="flow-diagram">
  <div class="flow-side">
    <div class="flow-tile flow-tile-phone" aria-label="Your iPhone">
      <div class="flow-tile-icon" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none">
          <rect x="6" y="2" width="12" height="20" rx="2.5" stroke="currentColor" stroke-width="1.5" />
          <circle cx="12" cy="18.5" r="0.9" fill="currentColor" />
          <rect x="9.5" y="4.25" width="5" height="0.9" rx="0.45" fill="currentColor" opacity="0.5" />
        </svg>
      </div>
      <div>
        <p class="flow-tile-title">Your iPhone</p>
        <p class="flow-tile-subtitle">Keychain · Strict TLS</p>
      </div>
    </div>
    <ul class="flow-bullets">
      <li><span class="dot dot-ok"></span> API tokens in iOS Keychain</li>
      <li><span class="dot dot-ok"></span> Biometric gate on high-risk actions</li>
      <li><span class="dot dot-ok"></span> No iCloud sync of credentials</li>
    </ul>
  </div>

  <div class="flow-link" aria-hidden="true">
    <svg viewBox="0 0 240 80" preserveAspectRatio="none" class="flow-link-svg">
      <defs>
        <linearGradient id="flowGrad" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="oklch(0.62 0.16 235 / 0)" />
          <stop offset="50%" stop-color="oklch(0.62 0.16 235 / 0.65)" />
          <stop offset="100%" stop-color="oklch(0.72 0.11 200 / 0)" />
        </linearGradient>
      </defs>
      <path
        d="M 0 40 C 80 40, 160 40, 240 40"
        fill="none"
        stroke="oklch(1 0 0 / 0.1)"
        stroke-width="1"
        stroke-dasharray="4 6"
      />
      <path
        d="M 0 40 C 80 40, 160 40, 240 40"
        fill="none"
        stroke="url(#flowGrad)"
        stroke-width="2"
        stroke-linecap="round"
        stroke-dasharray="3 80"
        class="flow-pulse"
      />
    </svg>
    <span class="flow-badge">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
        <rect x="5" y="10" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.6" />
        <path d="M8 10V7a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.6" />
      </svg>
      <span>HTTPS · WSS · direct</span>
    </span>
  </div>

  <div class="flow-side">
    <div class="flow-tile flow-tile-server" aria-label="Your TrueNAS server">
      <div class="flow-tile-icon" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none">
          <rect x="3" y="4" width="18" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.5" />
          <rect x="3" y="14.5" width="18" height="5.5" rx="1.5" stroke="currentColor" stroke-width="1.5" />
          <circle cx="6.5" cy="6.75" r="0.9" fill="currentColor" />
          <circle cx="6.5" cy="17.25" r="0.9" fill="currentColor" />
          <path d="M10 6.75h7M10 17.25h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </div>
      <div>
        <p class="flow-tile-title">Your TrueNAS</p>
        <p class="flow-tile-subtitle">SCALE 24.04+</p>
      </div>
    </div>
    <ul class="flow-bullets">
      <li><span class="dot dot-ok"></span> WebSocket JSON-RPC primary</li>
      <li><span class="dot dot-ok"></span> REST v2.0 fallback</li>
      <li><span class="dot dot-ok"></span> Self-signed certs SHA-256 pinned</li>
    </ul>
  </div>

  <p class="flow-disclaimer">
    Nothing in between. No developer-operated backend, no third-party relay,
    no app telemetry endpoint.
  </p>
</div>

<style>
  .flow-diagram {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: stretch;
    border: 1px solid var(--color-stroke-soft);
    border-radius: 1rem;
    background: oklch(from var(--color-surface) l c h / 0.40);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 1.75rem;
    overflow: hidden;
  }
  /* Glass top-edge highlight on the outer container */
  .flow-diagram::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, oklch(1 0 0 / 0.12) 25%, oklch(1 0 0 / 0.12) 75%, transparent 100%);
    pointer-events: none;
  }
  @media (min-width: 768px) {
    .flow-diagram {
      grid-template-columns: 1fr auto 1fr;
      gap: 1rem;
      align-items: center;
      padding: 2.25rem;
    }
  }

  .flow-side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .flow-tile {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 1.125rem;
    border-radius: 0.75rem;
    background: oklch(from var(--color-surface-raised) l c h / 0.55);
    border: 1px solid var(--color-stroke-soft);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    overflow: hidden;
  }
  .flow-tile::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, oklch(1 0 0 / 0.13) 40%, oklch(1 0 0 / 0.13) 60%, transparent 100%);
    pointer-events: none;
  }
  .flow-tile-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 0.5rem;
    background: oklch(from var(--color-accent) l c h / 0.10);
    color: var(--color-accent);
    box-shadow: inset 0 0 0 1px oklch(from var(--color-accent) l c h / 0.18);
    flex-shrink: 0;
  }
  .flow-tile-server .flow-tile-icon {
    color: var(--color-accent-secondary);
    background: oklch(from var(--color-accent-secondary) l c h / 0.10);
    box-shadow: inset 0 0 0 1px oklch(from var(--color-accent-secondary) l c h / 0.20);
  }
  .flow-tile-title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .flow-tile-subtitle {
    margin: 0.15rem 0 0 0;
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .flow-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }
  .flow-bullets li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-ok {
    background: var(--color-ok);
    box-shadow: 0 0 8px oklch(from var(--color-ok) l c h / 0.55);
  }

  .flow-link {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 80px;
  }
  .flow-link-svg {
    width: 100%;
    max-width: 280px;
    height: 80px;
  }
  .flow-pulse {
    animation: flow-pulse-anim 4.5s linear infinite;
  }
  @keyframes flow-pulse-anim {
    0%   { stroke-dashoffset: 320; }
    100% { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .flow-pulse { animation: none; opacity: 0.6; }
  }
  .flow-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    background: oklch(from var(--color-bg-elevated) l c h / 0.85);
    border: 1px solid var(--color-stroke-soft);
    color: var(--color-text-secondary);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: -0.5rem;
    backdrop-filter: blur(4px);
  }

  .flow-disclaimer {
    grid-column: 1 / -1;
    margin: 0.5rem 0 0 0;
    text-align: center;
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    border-top: 1px solid var(--color-stroke-soft);
    padding-top: 1rem;
  }
</style>
