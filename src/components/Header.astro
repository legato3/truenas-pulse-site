---
import { site, navLinks } from "~/data/site";

const path = Astro.url.pathname.replace(/\/$/, "");
---

<header
  class="sticky top-0 z-40 border-b border-stroke-soft bg-bg/80 backdrop-blur-md backdrop-saturate-150"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3">
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2.5 text-text transition-opacity hover:opacity-80"
      aria-label={`${site.name} home`}
    >
      <img
        src="/icon-192.png"
        alt=""
        width="28"
        height="28"
        class="h-7 w-7 rounded-md ring-1 ring-stroke-strong"
        decoding="async"
      />
      <span class="text-[15px] font-semibold tracking-tight">{site.name}</span>
    </a>

    <!-- Desktop nav (hidden on mobile) -->
    <nav class="hidden items-center gap-1 text-sm sm:flex" aria-label="Primary">
      {
        navLinks.map((link) => {
          const active = path === link.href.replace(/\/$/, "");
          return (
            <a
              href={link.href}
              class:list={[
                "rounded-md px-3 py-1.5 transition-colors",
                active
                  ? "text-text bg-surface"
                  : "text-text-secondary hover:text-text hover:bg-surface/60",
              ]}
              aria-current={active ? "page" : undefined}
            >
              {link.label}
            </a>
          );
        })
      }
      <a
        href={site.appStoreUrl}
        target="_blank"
        rel="noopener"
        class="ml-2 rounded-md bg-text px-3 py-1.5 text-[13px] font-medium text-bg transition-opacity hover:opacity-90"
      >
        App Store
      </a>
    </nav>

    <!-- Mobile right side: App Store button + hamburger -->
    <div class="flex items-center gap-2 sm:hidden">
      <a
        href={site.appStoreUrl}
        target="_blank"
        rel="noopener"
        class="rounded-md bg-text px-3 py-1.5 text-[13px] font-medium text-bg transition-opacity hover:opacity-90"
      >
        App Store
      </a>
      <button
        id="mobile-menu-btn"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="flex h-8 w-8 items-center justify-center rounded-md text-text-secondary transition-colors hover:bg-surface hover:text-text"
      >
        <!-- Hamburger icon -->
        <svg id="icon-open" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2 5h14M2 9h14M2 13h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <!-- Close icon, hidden by default -->
        <svg id="icon-close" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" class="hidden">
          <path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <nav
    id="mobile-menu"
    aria-label="Mobile navigation"
    class="hidden border-t border-stroke-soft px-5 pb-4 pt-3 sm:hidden"
  >
    <ul class="flex flex-col gap-1 text-sm">
      {
        navLinks.map((link) => {
          const active = path === link.href.replace(/\/$/, "");
          return (
            <li>
              <a
                href={link.href}
                class:list={[
                  "block rounded-md px-3 py-2 transition-colors",
                  active
                    ? "text-text bg-surface"
                    : "text-text-secondary hover:text-text hover:bg-surface/60",
                ]}
                aria-current={active ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  function setOpen(open: boolean) {
    menu?.classList.toggle("hidden", !open);
    iconOpen?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
    btn?.setAttribute("aria-expanded", String(open));
    btn?.setAttribute("aria-label", open ? "Close navigation menu" : "Open navigation menu");
  }

  btn?.addEventListener("click", () => {
    const isOpen = btn.getAttribute("aria-expanded") === "true";
    setOpen(!isOpen);
  });

  // Close menu when a link is clicked
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setOpen(false));
  });

  // Close on outside click
  document.addEventListener("click", (e) => {
    if (btn && menu && !btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
      setOpen(false);
    }
  });
</script>
