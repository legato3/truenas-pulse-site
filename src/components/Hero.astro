---
import { site } from "~/data/site";
import AppStoreButton from "~/components/AppStoreButton.astro";
import DeviceFrame from "~/components/DeviceFrame.astro";
import AmbientGrid from "~/components/AmbientGrid.astro";
---

<section class="relative overflow-hidden device-stage">
  <AmbientGrid />

  <div
    class="relative z-10 mx-auto max-w-6xl px-5 pt-20 pb-24 sm:pt-28 sm:pb-32 lg:grid lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center lg:gap-16"
  >
    <div class="reveal-init">
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-stroke-soft bg-surface/60 px-3 py-1 text-xs text-text-secondary backdrop-blur">
        <span class="status-dot status-dot-pulse"></span>
        <span>Native iOS &middot; TrueNAS SCALE &middot; <span class="font-mono">v{site.latestVersion}</span></span>
      </div>

      <h1
        class="text-balance text-[clamp(2.25rem,6vw,4rem)] font-semibold leading-[1.05] tracking-[-0.02em] text-text"
      >
        Your server.
        <span class="block hero-headline-accent">At a glance.</span>
      </h1>

      <p
        class="mt-6 max-w-xl text-pretty text-base leading-relaxed text-text-secondary sm:text-lg"
      >
        {site.tagline}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <AppStoreButton size="lg" />
        <a
          href="/features"
          class="inline-flex items-center gap-1.5 rounded-lg border border-stroke-strong px-5 py-3.5 text-sm font-medium text-text transition-colors hover:bg-surface/60"
        >
          Explore features
          <svg
            width="14"
            height="14"
            viewBox="0 0 14 14"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M5 3l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
      <p class="mt-3 text-xs text-text-tertiary">
        Or
        <a
          href={site.testFlightUrl}
          target="_blank"
          rel="noopener"
          class="underline underline-offset-2 transition-colors hover:text-text-secondary"
        >join the beta on TestFlight</a> to try upcoming builds early.
      </p>

      <ul
        class="mt-10 grid grid-cols-1 gap-3 text-sm text-text-secondary sm:grid-cols-2"
      >
        <li class="flex items-start gap-2">
          <span class="status-dot mt-1.5"></span>
          <span>Live monitoring · <span class="font-mono text-text-tertiary">15 s</span> refresh · <span class="font-mono text-text-tertiary">1 h</span> history</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="status-dot mt-1.5"></span>
          <span>Up to <span class="font-mono text-text-tertiary">2</span> servers free, <span class="font-mono text-text-tertiary">8</span> with Pro</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="status-dot mt-1.5"></span>
          <span>iOS Keychain credentials · strict TLS · no relay</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="status-dot mt-1.5"></span>
          <span>Zero analytics. Zero third-party SDKs. One-time purchase.</span>
        </li>
      </ul>
    </div>

    <div class="reveal-init mt-16 flex justify-center lg:mt-0" data-reveal-delay="180">
      <DeviceFrame
        ariaLabel="TrueNAS Pulse dashboard — Goldeye server, READY, 22.3 of 33.2 TB used, CPU 4 percent, memory 78 percent, storage healthy"
        realScreenshot
      >
        <picture>
          <source type="image/avif" srcset="/screenshots/01-dashboard.avif" />
          <source type="image/webp" srcset="/screenshots/01-dashboard.webp" />
          <img
            src="/screenshots/01-dashboard.webp"
            alt=""
            width="1180"
            height="2564"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
      </DeviceFrame>
    </div>
  </div>
</section>

<style>
  /* Headline accent uses a subtle brand-tinted gradient — no rainbow. */
  .hero-headline-accent {
    background: linear-gradient(
      90deg,
      var(--color-text-secondary) 0%,
      oklch(0.74 0.12 240 / 0.95) 60%,
      var(--color-text-secondary) 100%
    );
    -webkit-background-clip: text;
            background-clip: text;
    color: transparent;
  }

  /* Pulse on the live status dot — matches /chat-server status pill */
  .status-dot-pulse {
    position: relative;
  }
  .status-dot-pulse::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid var(--color-ok);
    opacity: 0;
    animation: pulse-ring 2.6s ease-out infinite;
  }
  @keyframes pulse-ring {
    0%   { transform: scale(0.6); opacity: 0.7; }
    100% { transform: scale(1.6); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .status-dot-pulse::after { animation: none; opacity: 0; }
  }

</style>
