---
import { site } from "~/data/site";
import AppStoreButton from "~/components/AppStoreButton.astro";
import DeviceFrame from "~/components/DeviceFrame.astro";
---

<section class="relative device-stage">
  <div
    class="relative z-10 mx-auto max-w-6xl px-5 pt-20 pb-24 sm:pt-28 sm:pb-32 lg:grid lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center lg:gap-16"
  >
    <div class="reveal-init">
      <h1
        class="text-balance text-[clamp(2.25rem,6vw,4rem)] font-semibold leading-[1.05] tracking-[-0.02em] text-text"
      >
        Your TrueNAS.
        <span class="block hero-headline-accent">At a glance.</span>
      </h1>

      <!-- ECG heartbeat pulse — brand signature, loops every 3.2s -->
      <div class="mt-5 mb-1" aria-hidden="true">
        <svg class="ecg-pulse" width="240" height="40" viewBox="0 0 240 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <!-- Horizontal gradient: transparent at both ends, opaque in the middle -->
            <linearGradient id="ecgFade" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%"   stop-color="white" stop-opacity="0" />
              <stop offset="7%"   stop-color="white" stop-opacity="1" />
              <stop offset="93%"  stop-color="white" stop-opacity="1" />
              <stop offset="100%" stop-color="white" stop-opacity="0" />
            </linearGradient>
            <mask id="ecgMask">
              <rect width="240" height="40" fill="url(#ecgFade)" />
            </mask>
          </defs>
          <!-- Both paths share the fade mask so both ends dissolve softly -->
          <g mask="url(#ecgMask)">
            <!-- Glow layer -->
            <path class="ecg-path ecg-glow"
              d="M0,20 H52 L55,18 L59,14 L62,20 H72 L76,4 L80,36 L84,20 H94 L97,24 L100,20 H240"
              stroke="oklch(0.62 0.16 235 / 0.35)"
              stroke-width="5"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="none"
            />
            <!-- Sharp line -->
            <path class="ecg-path ecg-line"
              d="M0,20 H52 L55,18 L59,14 L62,20 H72 L76,4 L80,36 L84,20 H94 L97,24 L100,20 H240"
              stroke="oklch(0.66 0.14 150)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="none"
            />
          </g>
        </svg>
      </div>

      <p
        class="mt-4 max-w-xl text-pretty text-base leading-relaxed text-text-secondary sm:text-lg"
      >
        A native third-party TrueNAS SCALE iPhone app with live health,
        alerts, storage visibility, widgets, and guarded remote actions.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <AppStoreButton size="lg" />
        <a
          href="/features"
          class="inline-flex items-center gap-1.5 rounded-lg border border-stroke-strong px-5 py-3.5 text-sm font-medium text-text transition-colors hover:bg-surface/60"
        >
          See features
          <svg
            width="14"
            height="14"
            viewBox="0 0 14 14"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M5 3l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
      <p class="mt-3 text-xs text-text-tertiary">
        Or
        <a
          href={site.testFlightUrl}
          target="_blank"
          rel="noopener"
          class="underline underline-offset-2 transition-colors hover:text-text-secondary"
        >join the beta on TestFlight</a> to try upcoming builds early.
      </p>

      <ul
        class="mt-10 grid grid-cols-1 gap-3 text-sm text-text-secondary sm:grid-cols-2"
      >
        <li class="flex items-start gap-2">
          <span class="status-dot mt-1.5"></span>
          <span>Live health, alerts, and 1-hour history</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="status-dot mt-1.5"></span>
          <span>2 servers free · 8 with Pro</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="status-dot mt-1.5"></span>
          <span>Pools, datasets, disks, and snapshots</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="status-dot mt-1.5"></span>
          <span>Guarded actions. No tracking. No third-party SDKs.</span>
        </li>
      </ul>
    </div>

    <div class="reveal-init mt-16 flex justify-center lg:mt-0" data-reveal-delay="180">
      <DeviceFrame
        ariaLabel="TrueNAS Pulse TrueNAS SCALE iPhone app dashboard — Goldeye server, READY, 22.3 of 33.2 TB used, CPU 4 percent, memory 78 percent, storage healthy"
        realScreenshot
      >
        <picture>
          <source type="image/avif" srcset="/screenshots/01-dashboard.avif" />
          <source type="image/webp" srcset="/screenshots/01-dashboard.webp" />
          <img
            src="/screenshots/01-dashboard.webp"
            alt=""
            width="1180"
            height="2564"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
      </DeviceFrame>
    </div>
  </div>
</section>

<style>
  /* ── Headline accent ────────────────────────────────────────────── */
  /* Headline accent uses a subtle brand-tinted gradient — no rainbow. */
  .hero-headline-accent {
    background: linear-gradient(
      90deg,
      var(--color-text-secondary) 0%,
      oklch(0.74 0.12 240 / 0.95) 60%,
      var(--color-text-secondary) 100%
    );
    -webkit-background-clip: text;
            background-clip: text;
    color: transparent;
    /* Prevent descender clipping (e.g. "g" in "glance") from tight leading */
    padding-bottom: 0.15em;
  }

  /* Pulse on the live status dot — matches /chat-server status pill */
  .status-dot-pulse {
    position: relative;
  }
  .status-dot-pulse::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid var(--color-ok);
    opacity: 0;
    animation: pulse-ring 2.6s ease-out infinite;
  }
  @keyframes pulse-ring {
    0%   { transform: scale(0.6); opacity: 0.7; }
    100% { transform: scale(1.6); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .status-dot-pulse::after { animation: none; opacity: 0; }
  }

  /* ECG heartbeat animation — draws the trace across, fades, repeats */
  .ecg-pulse {
    overflow: visible;
    display: block;
  }
  .ecg-path {
    /* Total path length ~310px — dasharray must be >= that */
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
    animation: ecg-sweep 3.2s cubic-bezier(0.4, 0, 0.55, 1) infinite;
  }
  .ecg-glow {
    filter: blur(4px);
    animation-delay: 0s;
  }
  .ecg-line {
    animation-delay: 0s;
  }
  @keyframes ecg-sweep {
    0%   { stroke-dashoffset: 500; opacity: 0; }
    4%   { opacity: 1; }
    55%  { stroke-dashoffset: 0;   opacity: 1; }
    78%  { stroke-dashoffset: 0;   opacity: 0.5; }
    100% { stroke-dashoffset: 0;   opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ecg-path {
      animation: none;
      stroke-dashoffset: 0;
      opacity: 0.4;
    }
  }

</style>
