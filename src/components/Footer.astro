---
import { site, footerLinks } from "~/data/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-stroke-soft mt-16">
  <div class="mx-auto max-w-6xl px-5 py-12">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div class="space-y-2">
        <div class="flex items-center gap-2.5 text-text">
          <img
            src="/icon-192.png"
            alt=""
            width="24"
            height="24"
            class="h-6 w-6 rounded-md ring-1 ring-stroke-strong"
            decoding="async"
            loading="lazy"
          />
          <span class="text-sm font-semibold">{site.name}</span>
        </div>
        <p class="text-xs text-text-tertiary max-w-md">
          {site.trademarkLine}
        </p>
      </div>

      <nav class="flex flex-wrap gap-x-5 gap-y-2 text-sm" aria-label="Footer">
        {
          footerLinks.map((link) => (
            <a
              href={link.href}
              class="text-text-secondary transition-colors hover:text-text"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div
      class="mt-10 flex flex-col gap-2 border-t border-stroke-soft pt-6 text-xs text-text-tertiary sm:flex-row sm:justify-between"
    >
      <span>&copy; {year} Christophe Cornelis. All rights reserved.</span>
      <span>{site.trustLine}</span>
    </div>
  </div>
</footer>
