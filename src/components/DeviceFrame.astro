---
/**
 * Pure-CSS iPhone-shaped device frame. No raster mock, no licensed Apple PNG.
 * Approximates iPhone 17 (393×852pt) at 2.5× CSS scale.
 *
 * The slot is rendered inside the screen area. Pass an <img> or any node;
 * we clip to the screen radius.
 *
 * Wrap with <DeviceFrame caption="..."> for the screenshot label.
 */
interface Props {
  caption?: string;
  /** Optional alt text for the screenshot loaded inside the frame. */
  ariaLabel?: string;
  /**
   * Real iPhone screenshots already include the Dynamic Island in the captured
   * pixels. Set true to suppress the CSS island overlay so the two don't
   * stack. Defaults to false (show CSS island for synthetic content).
   */
  realScreenshot?: boolean;
  /** Render at the bigger spotlight size (used by /screenshots). */
  size?: "default" | "large";
}
const {
  caption,
  ariaLabel,
  realScreenshot = false,
  size = "default",
} = Astro.props;
---

<figure class="device-frame" role="img" aria-label={ariaLabel || caption}>
  <div class:list={["device-shell", size === "large" && "is-large"]}>
    <!-- Physical controls make the frame read as an iPhone silhouette. -->
    <span class="device-button device-button-action" aria-hidden="true"></span>
    <span class="device-button device-button-volume-up" aria-hidden="true"></span>
    <span class="device-button device-button-volume-down" aria-hidden="true"></span>
    <span class="device-button device-button-power" aria-hidden="true"></span>
    <span class="device-button device-button-camera" aria-hidden="true"></span>
    <!-- Bezel highlight (top edge gloss) -->
    <span class="device-gloss" aria-hidden="true"></span>
    <!-- Screen + content slot -->
    <div class="device-screen">
      <slot />
    </div>
    <!-- Dynamic Island — only when content is synthetic; real screenshots already include it -->
    {!realScreenshot && <span class="device-island" aria-hidden="true"></span>}
  </div>
  {caption && <figcaption class="device-caption">{caption}</figcaption>}
</figure>

<style>
  .device-frame {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .device-shell {
    /* Wider clamp so frames scale up on big screens (gallery + hero) */
    --frame-w: clamp(220px, 32vw, 380px);
    --frame-radius: clamp(34px, calc(var(--frame-w) * 0.135), 58px);
    --screen-radius: calc(var(--frame-radius) - 5px);
    --content-radius: calc(var(--screen-radius) - 6px);
    --bezel: clamp(3px, calc(var(--frame-w) * 0.01), 5px);
    --glass-inset: clamp(5px, calc(var(--frame-w) * 0.018), 8px);
    --rail-light: oklch(0.34 0.004 250);
    --rail: oklch(0.23 0.004 250);
    --rail-dark: oklch(0.10 0.003 250);

    position: relative;
    width: var(--frame-w);
    aspect-ratio: 9 / 19.5;
    border-radius: var(--frame-radius);
    background:
      linear-gradient(
        90deg,
        var(--rail-light) 0%,
        var(--rail) 8%,
        var(--rail-dark) 18%,
        oklch(0.18 0.003 250) 50%,
        var(--rail-dark) 80%,
        var(--rail-light) 100%
      ),
      linear-gradient(180deg, oklch(0.34 0.004 250), oklch(0.10 0.003 250));
    padding: var(--bezel);
    isolation: isolate;
    box-shadow:
      0 0 0 1px oklch(1 0 0 / 0.05) inset,
      0 0 0 2px oklch(0 0 0 / 0.72),
      0 2px 2px oklch(1 0 0 / 0.08) inset,
      0 -2px 3px oklch(0 0 0 / 0.55) inset,
      0 36px 72px -30px oklch(0 0 0 / 0.88);
  }

  .device-shell.is-large {
    --frame-w: clamp(280px, 42vw, 460px);
    --frame-radius: clamp(44px, calc(var(--frame-w) * 0.13), 66px);
  }

  .device-shell::before {
    content: "";
    position: absolute;
    inset: calc(var(--bezel) + 1px);
    z-index: 1;
    border-radius: var(--screen-radius);
    pointer-events: none;
    box-shadow:
      0 0 0 1px oklch(1 0 0 / 0.045),
      0 0 0 1px oklch(0 0 0 / 0.72) inset;
  }

  .device-button {
    position: absolute;
    width: 4px;
    border-radius: 999px;
    background:
      linear-gradient(
        90deg,
        oklch(0.12 0.003 250),
        oklch(0.34 0.004 250) 42%,
        oklch(0.16 0.003 250)
      );
    box-shadow:
      0 0 0 1px oklch(0 0 0 / 0.55),
      0 1px 0 oklch(1 0 0 / 0.08) inset;
  }
  .device-button-action {
    left: -3px;
    top: 12.8%;
    height: 28px;
  }
  .device-button-volume-up {
    left: -4px;
    top: 20.8%;
    height: 54px;
  }
  .device-button-volume-down {
    left: -4px;
    top: 30.5%;
    height: 54px;
  }
  .device-button-power {
    right: -4px;
    top: 24.5%;
    height: 82px;
  }
  .device-button-camera {
    right: -4px;
    top: 40.5%;
    height: 56px;
  }

  .device-gloss {
    position: absolute;
    inset: 1px;
    z-index: 3;
    border-radius: var(--frame-radius);
    background:
      linear-gradient(180deg, oklch(1 0 0 / 0.055) 0%, transparent 16%),
      linear-gradient(90deg, oklch(1 0 0 / 0.045), transparent 12%, transparent 88%, oklch(1 0 0 / 0.04));
    pointer-events: none;
  }

  .device-screen {
    width: 100%;
    height: 100%;
    border-radius: var(--screen-radius);
    background: oklch(0.07 0 0);
    overflow: hidden;
    position: relative;
    z-index: 2;
    padding: var(--glass-inset);
    box-shadow:
      0 0 0 1px oklch(0 0 0 / 0.90),
      0 0 0 2px oklch(1 0 0 / 0.035) inset,
      0 0 10px oklch(0 0 0 / 0.50) inset;
  }

  .device-screen :global(picture) {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: var(--content-radius);
    overflow: hidden;
  }

  .device-screen :global(img),
  .device-screen :global(video) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--content-radius);
    display: block;
  }

  /* Dynamic Island — sits inside the bezel, on top of the screen */
  .device-island {
    position: absolute;
    top: calc(var(--bezel) + 8px);
    z-index: 4;
    left: 50%;
    transform: translateX(-50%);
    width: 28%;
    height: 22px;
    border-radius: 999px;
    background: oklch(0 0 0);
    box-shadow: 0 0 0 1px oklch(0 0 0 / 0.6);
  }

  .device-caption {
    color: var(--color-text-tertiary);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>
