---
/**
 * Pure-CSS iPhone-shaped device frame. No raster mock, no licensed Apple PNG.
 * Approximates iPhone 17 (393×852pt) at 2.5× CSS scale.
 *
 * The slot is rendered inside the screen area. Pass an <img> or any node;
 * we clip to the screen radius.
 *
 * Wrap with <DeviceFrame caption="..."> for the screenshot label.
 */
interface Props {
  caption?: string;
  /** Optional alt text for the screenshot loaded inside the frame. */
  ariaLabel?: string;
  /**
   * Real iPhone screenshots already include the Dynamic Island in the captured
   * pixels. Set true to suppress the CSS island overlay so the two don't
   * stack. Defaults to false (show CSS island for synthetic content).
   */
  realScreenshot?: boolean;
  /** Render at the bigger spotlight size (used by /screenshots). */
  size?: "default" | "large";
}
const {
  caption,
  ariaLabel,
  realScreenshot = false,
  size = "default",
} = Astro.props;
---

<figure class="device-frame" role="img" aria-label={ariaLabel || caption}>
  <div class:list={["device-shell", size === "large" && "is-large"]}>
    <!-- Bezel highlight (top edge gloss) -->
    <span class="device-gloss" aria-hidden="true"></span>
    <!-- Screen + content slot -->
    <div class="device-screen">
      <slot />
    </div>
    <!-- Dynamic Island — only when content is synthetic; real screenshots already include it -->
    {!realScreenshot && <span class="device-island" aria-hidden="true"></span>}
  </div>
  {caption && <figcaption class="device-caption">{caption}</figcaption>}
</figure>

<style>
  .device-frame {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .device-shell {
    /* Wider clamp so frames scale up on big screens (gallery + hero) */
    --frame-w: clamp(220px, 32vw, 380px);
    --frame-radius: 14%;
    /* Thinner bezel — modern iPhone proportions */
    --bezel: 6px;

    position: relative;
    width: var(--frame-w);
    aspect-ratio: 9 / 19.5;
    border-radius: var(--frame-radius);
    background:
      /* Subtle inner highlight so the bezel reads as titanium */
      linear-gradient(
        135deg,
        oklch(0.36 0.005 250) 0%,
        oklch(0.22 0.005 250) 35%,
        oklch(0.16 0.005 250) 65%,
        oklch(0.28 0.005 250) 100%
      );
    padding: var(--bezel);
    box-shadow:
      /* Inner specular */
      0 1px 0 oklch(1 0 0 / 0.10) inset,
      0 -1px 0 oklch(0 0 0 / 0.4) inset,
      /* Edge */
      0 0 0 1px oklch(0 0 0 / 0.55),
      /* Cast shadow */
      0 40px 80px -25px oklch(0 0 0 / 0.85),
      /* Brand-tinted ambient glow */
      0 0 80px oklch(0.74 0.12 240 / 0.10);
  }

  .device-shell.is-large {
    --frame-w: clamp(280px, 42vw, 460px);
  }

  .device-gloss {
    position: absolute;
    inset: 0;
    border-radius: var(--frame-radius);
    background: linear-gradient(
      180deg,
      oklch(1 0 0 / 0.07) 0%,
      transparent 18%
    );
    pointer-events: none;
  }

  .device-screen {
    width: 100%;
    height: 100%;
    border-radius: calc(var(--frame-radius) - 1.4%);
    background: oklch(0.07 0 0);
    overflow: hidden;
    position: relative;
  }

  .device-screen :global(img),
  .device-screen :global(video) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Dynamic Island — sits inside the bezel, on top of the screen */
  .device-island {
    position: absolute;
    top: calc(var(--bezel) + 8px);
    left: 50%;
    transform: translateX(-50%);
    width: 28%;
    height: 22px;
    border-radius: 999px;
    background: oklch(0 0 0);
    box-shadow: 0 0 0 1px oklch(0 0 0 / 0.6);
  }

  .device-caption {
    color: var(--color-text-tertiary);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>
