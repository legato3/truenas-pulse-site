---
/**
 * Free vs Pro comparison — two columns. Pro is the only purchasable tier;
 * everything in the app is reachable through Free or Pro.
 *
 * Copy lifted from MONETIZATION.md §1 Value Split, condensed to scannable
 * one-liners. The trust footer language matches MONETIZATION.md verbatim.
 */
import { site } from "~/data/site";
import AppStoreButton from "~/components/AppStoreButton.astro";

interface Row {
  label: string;
  free: string | true;
  pro: string | true;
}

const rows: Row[] = [
  { label: "Live monitoring", free: true, pro: true },
  { label: "Reporting history", free: "Live + 1H", pro: "Live + 1H, 6H, 24H, 7D, 30D" },
  { label: "Servers", free: "Up to 2", pro: "Up to 8" },
  { label: "Local monitor", free: "1 on active server", pro: "Unlimited across servers" },
  { label: "Pool, disk, dataset health", free: true, pro: true },
  { label: "Alerts (read + acknowledge)", free: true, pro: true },
  { label: "Home Screen widget", free: true, pro: true },
  { label: "Filesystem browser & audit log", free: "Read-only", pro: "Read-only" },
  { label: "Fleet view & server comparison", free: "—", pro: true },
  { label: "Config drift comparison", free: "—", pro: true },
  { label: "Service / app / VM lifecycle", free: "—", pro: true },
  { label: "Disk & VDEV management", free: "—", pro: true },
  { label: "Manual snapshots (delete, clone, rollback)", free: "Create only", pro: true },
  { label: "Network editing", free: "—", pro: true },
  { label: "Share management (SMB / NFS)", free: "—", pro: true },
  { label: "Data protection controls", free: "View only", pro: true },
  { label: "Power operations & system update install", free: "—", pro: true },
  { label: "Live log streaming", free: "—", pro: true },
  { label: "Terminal (web shell)", free: "—", pro: true },
  { label: "Config backup / restore / support bundle", free: "—", pro: true },
  { label: "Batch actions", free: "—", pro: true },
  { label: "iCloud Sync · Live Activities", free: "—", pro: true },
];

const cell = (val: string | true) => (val === true ? "✓" : val);
---

<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
  {/* Free */}
  <div class="card tier-card tier-card-free rounded-2xl border border-stroke-soft p-7">
    <header class="mb-5">
      <p class="tier-badge tier-badge-free mb-2 inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-[11px] font-medium uppercase tracking-[0.12em]">
        <span class="status-dot" style="width: 0.4rem; height: 0.4rem;"></span>
        Free, genuinely
      </p>
      <h3 class="mt-2 text-2xl font-semibold tracking-tight text-text">
        Useful forever monitoring
      </h3>
      <p class="mt-2 text-sm leading-relaxed text-text-secondary">
        Monitor your own TrueNAS setup for up to 2 servers. No trial, no demo
        trap, no time limit.
      </p>
    </header>
    <div class="tier-price-row mb-6 flex items-baseline gap-2">
      <span class="tier-price text-5xl text-text">$0</span>
      <span class="text-sm text-text-tertiary">forever</span>
    </div>
    <ul class="space-y-2 text-sm leading-relaxed text-text-secondary">
      <li class="flex items-start gap-2">
        <span class="mt-1 text-ok">✓</span>
        <span>Live dashboard, alerts, storage health, jobs, and services view</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="mt-1 text-ok">✓</span>
        <span>1-hour reporting history (CPU, memory, network)</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="mt-1 text-ok">✓</span>
        <span>One proactive monitor on the active server</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="mt-1 text-ok">✓</span>
        <span>TrueNAS 26 container lifecycle (start, stop, force-stop)</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="mt-1 text-ok">✓</span>
        <span>Filesystem browser + audit log (read-only)</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="mt-1 text-ok">✓</span>
        <span>Manual ZFS snapshot creation</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="mt-1 text-ok">✓</span>
        <span>Home Screen widget for glanceable status</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="mt-1 text-ok">✓</span>
        <span>Up to 2 servers with fast switching</span>
      </li>
    </ul>
  </div>

  {/* Pro */}
  <div
    class="card tier-card tier-card-pro relative rounded-2xl border border-accent/40 p-7 shadow-[0_0_50px_-22px_oklch(0.62_0.16_235/0.35)]"
  >
    <span
      class="tier-badge tier-badge-pro absolute right-4 top-4 rounded-full px-2.5 py-1 text-[11px] font-medium uppercase tracking-wider"
    >
      Lifetime · Pay once
    </span>
    <header class="mb-5">
      <p class="mb-2 text-xs font-medium uppercase tracking-[0.18em] text-text-tertiary">
        TrueNAS Pulse Pro
      </p>
      <h3 class="text-2xl font-semibold tracking-tight text-text">
        More servers · deeper tools
      </h3>
      <p class="mt-2 text-sm leading-relaxed text-text-secondary">
        For serious operators managing more servers, investigating incidents,
        and using advanced guarded actions. One-time purchase — no subscription,
        no expiry.
      </p>
    </header>
    <div class="mb-6 grid grid-cols-2 gap-2">
      <span class="tier-chip">8 servers</span>
      <span class="tier-chip">30-day history</span>
      <span class="tier-chip">Fleet view</span>
      <span class="tier-chip">Terminal</span>
    </div>
    <div class="tier-price-row mb-6 flex items-baseline gap-2">
      <span class="tier-price text-5xl text-text">$9.99</span>
      <span class="text-sm text-text-tertiary">localized via App Store</span>
    </div>
    <AppStoreButton size="md" />
    <p class="mt-3 text-xs text-text-tertiary">
      Pay once through the App Store. Free remains useful if you never upgrade.
    </p>
    <p class="mt-2 text-xs text-text-tertiary">
      Want to try before you buy?
      <a
        href={site.testFlightUrl}
        target="_blank"
        rel="noopener"
        class="underline underline-offset-2 transition-colors hover:text-text-secondary"
      >Join the beta on TestFlight.</a>
    </p>
  </div>
</div>

<div
  class="card compare-table-card mt-10 overflow-hidden rounded-xl border border-stroke-soft"
>
  <table class="compare-table w-full text-sm">
    <thead class="border-b border-stroke-soft text-xs uppercase tracking-[0.12em] text-text-tertiary">
      <tr>
        <th class="px-5 py-2.5 text-left font-medium">Feature</th>
        <th class="whitespace-nowrap px-5 py-2.5 text-center font-medium">Free</th>
        <th class="whitespace-nowrap px-5 py-2.5 text-center font-medium">Pro</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row, i) => (
          <tr
            class:list={[
              "border-t border-stroke-soft",
              /* Zebra goes lighter, not darker — dark-theme convention. A
                 white-alpha overlay reads as a 'lifted' row regardless of
                 the base surface's lightness. bg-bg-elevated (0.165) over
                 bg-surface (0.20) had the rows sinking instead. */
              i % 2 === 1 && "bg-[oklch(1_0_0_/_0.025)]",
            ]}
          >
            <td class="px-5 py-2.5 text-text-secondary">{row.label}</td>
            <td
              class:list={[
                "compare-value whitespace-nowrap px-5 py-2.5 text-center",
                row.free === "—" ? "text-text-tertiary" : "text-text",
              ]}
            >
              {row.free === true ? <span class="compare-check">✓</span> : cell(row.free)}
            </td>
            <td class="compare-value whitespace-nowrap px-5 py-2.5 text-center text-text">
              {row.pro === true ? <span class="compare-check">✓</span> : cell(row.pro)}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<p class="mt-6 text-center text-xs text-text-tertiary">
  {site.trustLine}
</p>

<style>
  .tier-card {
    background:
      linear-gradient(180deg, oklch(from var(--color-surface-raised) l c h / 0.62), oklch(from var(--color-surface) l c h / 0.52)),
      radial-gradient(circle at 18% 0%, oklch(from var(--color-accent) l c h / 0.10), transparent 42%);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .tier-card-pro {
    background:
      linear-gradient(180deg, oklch(from var(--color-surface-raised) l c h / 0.66), oklch(from var(--color-surface) l c h / 0.54)),
      radial-gradient(circle at 92% 0%, oklch(from var(--color-accent) l c h / 0.18), transparent 38%);
  }

  .tier-badge {
    border: 1px solid var(--color-stroke-soft);
    background: oklch(from var(--color-bg-elevated) l c h / 0.68);
  }

  .tier-badge-free {
    color: var(--color-ok);
    box-shadow: inset 0 0 0 1px oklch(from var(--color-ok) l c h / 0.10);
  }

  .tier-badge-pro {
    color: var(--color-accent);
    background: oklch(from var(--color-accent) l c h / 0.14);
  }

  .tier-price-row {
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-stroke-soft);
  }

  .tier-price {
    font-weight: 650;
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .tier-chip {
    border: 1px solid var(--color-stroke-soft);
    border-radius: 0.625rem;
    background: oklch(from var(--color-bg-elevated) l c h / 0.52);
    padding: 0.55rem 0.65rem;
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
    line-height: 1.25;
  }

  .compare-table-card {
    background: oklch(from var(--color-surface-raised) l c h / 0.46);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .compare-table thead {
    background: oklch(from var(--color-bg-elevated) l c h / 0.72);
  }

  .compare-table tbody tr {
    transition: background-color 160ms ease, color 160ms ease;
  }

  .compare-table tbody tr:hover {
    background: oklch(from var(--color-accent) l c h / 0.055);
  }

  .compare-value {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0;
  }

  .compare-check {
    color: var(--color-ok);
    font-weight: 650;
  }
</style>
