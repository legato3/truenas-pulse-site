---
import type { Screenshot } from "~/data/screenshots";
import DeviceFrame from "~/components/DeviceFrame.astro";

interface Props {
  shot: Screenshot;
  /** Eager-load the first card; lazy the rest. */
  eager?: boolean;
}

const { shot, eager = false } = Astro.props;
---

<article class="screenshot-card">
  <DeviceFrame
    ariaLabel={`TrueNAS Pulse — ${shot.title}. ${shot.caption}`}
    realScreenshot
  >
    <picture>
      <source type="image/avif" srcset={`/screenshots/${shot.slug}.avif`} />
      <source type="image/webp" srcset={`/screenshots/${shot.slug}.webp`} />
      <img
        src={`/screenshots/${shot.slug}.webp`}
        alt=""
        width={shot.width}
        height={shot.height}
        loading={eager ? "eager" : "lazy"}
        decoding="async"
      />
    </picture>
  </DeviceFrame>
  <div class="screenshot-text">
    <header class="mb-1.5 flex items-center gap-2">
      <h3 class="text-base font-semibold tracking-tight text-text">
        {shot.title}
      </h3>
      {
        shot.tier === "Pro" && (
          <span class="rounded-full bg-accent/14 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-accent">
            Pro
          </span>
        )
      }
    </header>
    <p class="text-sm leading-relaxed text-text-secondary">{shot.caption}</p>
  </div>
</article>

<style>
  .screenshot-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem 1.25rem;
    border-radius: 1.25rem;
    border: 1px solid var(--color-stroke-soft);
    background: oklch(from var(--color-surface) l c h / 0.4);
    transition: border-color 0.18s ease;
  }
  .screenshot-card:hover {
    border-color: var(--color-stroke-strong);
  }
  .screenshot-text {
    text-align: center;
    max-width: 22rem;
  }
</style>
