---
import BaseLayout from "~/components/BaseLayout.astro";
import Section from "~/components/Section.astro";
import ScreenshotCard from "~/components/ScreenshotCard.astro";
import CallToAction from "~/components/CallToAction.astro";
import { screenshots } from "~/data/screenshots";
---

<BaseLayout
  title="Screenshots"
  description="A walkthrough of TrueNAS Pulse on iPhone — dashboard, storage, sharing, workloads, fleet, reporting, and the Home Screen widget."
>
  <Section
    eyebrow="The app"
    heading="A walkthrough."
    lede="Captured on iPhone 17. Free unless marked Pro."
  >
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        screenshots.map((shot, i) => (
          <ScreenshotCard shot={shot} eager={i < 3} />
        ))
      }
    </div>
  </Section>

  <CallToAction />
</BaseLayout>
