---
import BaseLayout from "~/components/BaseLayout.astro";
import Section from "~/components/Section.astro";
import FeatureGrid from "~/components/FeatureGrid.astro";
import CallToAction from "~/components/CallToAction.astro";
---

<BaseLayout
  title="Features"
  description="Everything TrueNAS Pulse can do — live monitoring, pool health, alerts, Control Mode admin actions, Home Screen widget, iCloud sync, and more. Free and Pro feature breakdown."
>
  <Section
    eyebrow="The complete inventory"
    heading="Every feature, every tier."
    lede="Free covers live monitoring and read-only operational visibility. Pro unlocks the complete operator toolset — fleet view, lifecycle controls, advanced reporting, log streaming, terminal, and more."
  >
    <FeatureGrid withHeadings />
  </Section>

  <CallToAction />
</BaseLayout>
