---
import BaseLayout from "~/components/BaseLayout.astro";
import Section from "~/components/Section.astro";
import FeatureGrid from "~/components/FeatureGrid.astro";
import CallToAction from "~/components/CallToAction.astro";
---

<BaseLayout
  title="TrueNAS SCALE iOS App Features"
  description="Explore TrueNAS Pulse features for TrueNAS SCALE monitoring on iPhone: live health, alerts, storage visibility, widgets, Control Mode actions, Free, and Pro."
>
  <Section
    eyebrow="The complete inventory"
    heading="Every feature, every tier."
    headingLevel="h1"
    lede="Free covers live monitoring and read-only operational visibility. Pro unlocks the complete operator toolset — fleet view, lifecycle controls, advanced reporting, log streaming, terminal, and more."
  >
    <FeatureGrid withHeadings />
  </Section>

  <CallToAction />
</BaseLayout>
