---
import BaseLayout from "~/components/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import Section from "~/components/Section.astro";
import PillarStrip from "~/components/PillarStrip.astro";
import CallToAction from "~/components/CallToAction.astro";
import MotionReveal from "~/components/MotionReveal.astro";
import StatsStrip from "~/components/StatsStrip.astro";
import SecurityFlow from "~/components/SecurityFlow.astro";
import FreeShowcase from "~/components/FreeShowcase.astro";
import AppStoreButton from "~/components/AppStoreButton.astro";
import Personas from "~/components/Personas.astro";
import PrivacyLabel from "~/components/PrivacyLabel.astro";

const outcomes = [
  {
    head: "Know if TrueNAS is healthy",
    body: "Live status for CPU, memory, network, pools, disks, and services.",
  },
  {
    head: "Catch alerts quickly",
    body: "Review alerts and monitor signals from your phone before they turn into incidents.",
  },
  {
    head: "Understand storage and jobs",
    body: "Check pool health, datasets, snapshots, middleware jobs, and audit context without opening the web UI.",
  },
  {
    head: "Act safely when needed",
    body: "State-changing operations sit behind Control Mode, expiry, and biometric confirmation where risk is higher.",
  },
  {
    head: "Use Pro when you need more reach",
    body: "For more servers, deeper history, fleet visibility, Server Console access, and advanced guarded actions.",
  },
] as const;
---

<BaseLayout description="TrueNAS Pulse is a third-party TrueNAS SCALE iPhone app for live monitoring, alerts, storage visibility, widgets, and guarded remote actions.">
  <Hero />

  <Section
    eyebrow="Why TrueNAS Pulse"
    heading="Built for quick checks and careful actions."
    lede="Open it for live status, storage health, alerts, and widgets. Switch into Control Mode only when a remote action needs deliberate confirmation."
  >
    <PillarStrip />
    <div class="mt-12">
      <MotionReveal>
        <StatsStrip />
      </MotionReveal>
    </div>
  </Section>

  <Section
    eyebrow="Who it's for"
    heading="If you operate TrueNAS, this is your phone surface."
    lede="Three angles. Pick the one that sounds like you."
  >
    <Personas />
  </Section>

  <Section
    eyebrow="Free, on purpose"
    heading="Start free. Stay free if you want to."
    lede="Free is useful forever for monitoring your own TrueNAS setup: two servers, live health, alerts, storage, jobs, widgets, and one proactive monitor at no cost."
  >
    <MotionReveal>
      <FreeShowcase />
    </MotionReveal>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <AppStoreButton size="md" />
      <a
        href="/pro"
        class="inline-flex items-center gap-1.5 rounded-lg border border-stroke-strong px-5 py-3 text-sm font-medium text-text transition-colors hover:bg-surface/60"
      >
        See what Pro adds
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path
            d="M5 3l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </Section>

  <Section
    eyebrow="Daily operation"
    heading="Know what needs attention."
    lede="TrueNAS Pulse keeps live health, alerts, storage, jobs, and guarded actions close on your iPhone. The full Free + Pro inventory lives on the Features page."
  >
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-5">
      {
        outcomes.map((item, i) => (
          <MotionReveal delay={i * 35}>
            <article class="card outcome-card h-full rounded-lg border border-stroke-soft p-5">
              <h3 class="mb-2 text-base font-semibold tracking-tight text-text">
                {item.head}
              </h3>
              <p class="text-sm leading-relaxed text-text-secondary">
                {item.body}
              </p>
            </article>
          </MotionReveal>
        ))
      }
    </div>
    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <a
        href="/features"
        class="inline-flex items-center gap-1.5 rounded-lg border border-stroke-strong px-5 py-3 text-sm font-medium text-text transition-colors hover:bg-surface/60"
      >
        See full feature inventory
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path
            d="M5 3l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
      <a
        href="/pro"
        class="inline-flex items-center gap-1.5 rounded-lg border border-stroke-strong px-5 py-3 text-sm font-medium text-text transition-colors hover:bg-surface/60"
      >
        See Pro tooling
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path
            d="M5 3l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </Section>

  <Section
    eyebrow="Security model"
    heading="Your servers, your credentials, your data."
    lede="Direct by default. No accounts, no in-app analytics, no tracking SDKs. TrueNAS Pulse talks directly to the servers you configure. Optional Cloud Push Relay is off by default and only used for background alert delivery."
  >
    <MotionReveal>
      <SecurityFlow />
    </MotionReveal>

    <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-3">
      <MotionReveal delay={60}>
        <div class="card security-detail-card h-full rounded-xl border border-stroke-soft p-7">
          <h3 class="mb-2 text-lg font-semibold tracking-tight text-text">
            Credential storage
          </h3>
          <ul class="space-y-2 text-sm leading-relaxed text-text-secondary">
            <li>API tokens stored exclusively in the iOS Keychain — never synced to iCloud.</li>
            <li>Strict TLS validation by default.</li>
            <li>Per-server self-signed certificate opt-in (SHA-256 fingerprint pinning).</li>
            <li>iCloud Sync (Pro) covers server list + monitors via your own private iCloud — credentials never travel.</li>
            <li>API tokens, credentials, passwords, and secrets are never sent to the optional Cloud Push Relay.</li>
          </ul>
        </div>
      </MotionReveal>
      <MotionReveal delay={120}>
        <div class="card security-detail-card h-full rounded-xl border border-stroke-soft p-7">
          <h3 class="mb-2 text-lg font-semibold tracking-tight text-text">
            Action safety
          </h3>
          <ul class="space-y-2 text-sm leading-relaxed text-text-secondary">
            <li>Control Mode gate before any state-changing action.</li>
            <li>Biometric confirmation required for high-risk actions.</li>
            <li>5-minute auto-expire on Control Mode sessions.</li>
            <li>Local action log — nothing leaves the device.</li>
          </ul>
        </div>
      </MotionReveal>
      <MotionReveal delay={180}>
        <PrivacyLabel compact />
      </MotionReveal>
    </div>
  </Section>

  <CallToAction />
</BaseLayout>

<style>
  .outcome-card,
  .security-detail-card {
    background: oklch(from var(--color-surface-raised) l c h / 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
</style>
