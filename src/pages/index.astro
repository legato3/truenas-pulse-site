---
import BaseLayout from "~/components/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import Section from "~/components/Section.astro";
import PillarStrip from "~/components/PillarStrip.astro";
import FeatureGrid from "~/components/FeatureGrid.astro";
import CallToAction from "~/components/CallToAction.astro";
import MotionReveal from "~/components/MotionReveal.astro";
import StatsStrip from "~/components/StatsStrip.astro";
import SecurityFlow from "~/components/SecurityFlow.astro";
import KeywordMarquee from "~/components/KeywordMarquee.astro";
import FreeShowcase from "~/components/FreeShowcase.astro";
import AppStoreButton from "~/components/AppStoreButton.astro";
import Personas from "~/components/Personas.astro";
import PrivacyLabel from "~/components/PrivacyLabel.astro";
---

<BaseLayout description="Monitor your TrueNAS SCALE server from your iPhone. Live pool status, storage health, smart alerts, and safe admin actions — free on the App Store.">
  <Hero />

  <Section
    eyebrow="Why TrueNAS Pulse"
    heading="Built the way an operator's tool should feel."
    lede="A calm dashboard, careful actions, and zero noise. Designed for the moments when something matters and you're not at your desk."
  >
    <PillarStrip />
    <div class="mt-12">
      <MotionReveal>
        <StatsStrip />
      </MotionReveal>
    </div>
  </Section>

  <Section
    eyebrow="Who it's for"
    heading="If you operate TrueNAS, this is your phone surface."
    lede="Three angles. Pick the one that sounds like you."
  >
    <Personas />
  </Section>

  <KeywordMarquee />

  <Section
    eyebrow="Free, on purpose"
    heading="Start free. Stay free if you want to."
    lede="The free tier is built to be useful on its own, not a demo for Pro. Two servers, full read-only operations, the Home Screen widget, one proactive monitor, and TrueNAS 26 container controls — all included."
  >
    <MotionReveal>
      <FreeShowcase />
    </MotionReveal>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <AppStoreButton size="md" />
      <a
        href="/pro"
        class="inline-flex items-center gap-1.5 rounded-lg border border-stroke-strong px-5 py-3 text-sm font-medium text-text transition-colors hover:bg-surface/60"
      >
        See what Pro adds
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path
            d="M5 3l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </Section>

  <Section
    eyebrow="Feature highlights"
    heading="Everything you need from the dashboard to the disk."
    lede="A quick tour of the Pro toolset. The full 27-feature inventory — Free + Pro — lives on the Features page."
  >
    <FeatureGrid limit={6} />
    <div class="mt-10 flex justify-center">
      <a
        href="/features"
        class="inline-flex items-center gap-1.5 rounded-lg border border-stroke-strong px-5 py-3 text-sm font-medium text-text transition-colors hover:bg-surface/60"
      >
        See all 27 features
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path
            d="M5 3l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </Section>

  <Section
    eyebrow="Security model"
    heading="Your servers, your credentials, your data."
    lede="No accounts. No cloud. No in-app analytics. No third-party SDKs. The app talks only to the servers you configure — full stop."
  >
    <MotionReveal>
      <SecurityFlow />
    </MotionReveal>

    <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-3">
      <MotionReveal delay={60}>
        <div class="h-full rounded-xl border border-stroke-soft bg-surface/60 p-7">
          <h3 class="mb-2 text-base font-semibold tracking-tight text-text">
            Credential storage
          </h3>
          <ul class="space-y-2 text-sm leading-relaxed text-text-secondary">
            <li>API tokens stored exclusively in the iOS Keychain — never synced to iCloud.</li>
            <li>Strict TLS validation by default.</li>
            <li>Per-server self-signed certificate opt-in (SHA-256 fingerprint pinning).</li>
            <li>iCloud Sync (Pro) covers server list + monitors via your own private iCloud — credentials never travel.</li>
            <li>No tokens or secrets are ever logged.</li>
          </ul>
        </div>
      </MotionReveal>
      <MotionReveal delay={120}>
        <div class="h-full rounded-xl border border-stroke-soft bg-surface/60 p-7">
          <h3 class="mb-2 text-base font-semibold tracking-tight text-text">
            Action safety
          </h3>
          <ul class="space-y-2 text-sm leading-relaxed text-text-secondary">
            <li>Control Mode gate before any state-changing action.</li>
            <li>Biometric confirmation required for high-risk actions.</li>
            <li>5-minute auto-expire on Control Mode sessions.</li>
            <li>Local action log — nothing leaves the device.</li>
          </ul>
        </div>
      </MotionReveal>
      <MotionReveal delay={180}>
        <PrivacyLabel compact />
      </MotionReveal>
    </div>
  </Section>

  <CallToAction />
</BaseLayout>
