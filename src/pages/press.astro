---
import BaseLayout from "~/components/BaseLayout.astro";
import Section from "~/components/Section.astro";
import { site } from "~/data/site";
---

<BaseLayout
  title="Press"
  description="Press kit and boilerplate for TrueNAS Pulse."
  noindex
>
  <Section eyebrow="Press kit" heading="Boilerplate, downloads, and contact." width="narrow">
    <div class="space-y-10 text-base leading-relaxed text-text-secondary">
      <div>
        <h3 class="mb-2 text-base font-semibold tracking-tight text-text">
          One-line description
        </h3>
        <p class="rounded-lg border border-stroke-soft bg-surface/60 p-5 font-mono text-[15px] text-text">
          {site.tagline}
        </p>
      </div>

      <div>
        <h3 class="mb-2 text-base font-semibold tracking-tight text-text">
          Two-paragraph boilerplate
        </h3>
        <div class="space-y-4 rounded-lg border border-stroke-soft bg-surface/60 p-5 text-[15px] text-text">
          <p>
            TrueNAS Pulse is a native iPhone client for TrueNAS SCALE,
            built for sysadmins, operators, and homelab users who need fast
            infrastructure visibility and safe remote remediation away from a
            browser. The free tier covers live monitoring, 1-hour history,
            alerts, storage health, jobs, services, one local monitor, and
            read-only operational visibility for up to two servers.
          </p>
          <p>
            TrueNAS Pulse Pro is a one-time, lifetime in-app purchase that
            adds the full operator toolset: fleet view across every server,
            unlimited monitors, 30 days of historical reporting, live log
            streaming, lifecycle controls, manual ZFS snapshots, share and
            network management, terminal, batch actions, and a higher 8-server
            cap. The app contains zero analytics, zero third-party SDKs, and
            never communicates with anything except the servers you configure.
          </p>
        </div>
      </div>

      <div>
        <h3 class="mb-2 text-base font-semibold tracking-tight text-text">
          Quick facts
        </h3>
        <dl class="grid grid-cols-1 gap-x-8 gap-y-3 rounded-lg border border-stroke-soft bg-surface/60 p-5 text-[15px] sm:grid-cols-2">
          <div class="flex justify-between border-b border-stroke-soft/60 pb-2">
            <dt class="text-text-tertiary">App name</dt>
            <dd class="font-mono text-text">TrueNAS Pulse</dd>
          </div>
          <div class="flex justify-between border-b border-stroke-soft/60 pb-2">
            <dt class="text-text-tertiary">Subtitle</dt>
            <dd class="font-mono text-text">Third-Party SCALE Monitor</dd>
          </div>
          <div class="flex justify-between border-b border-stroke-soft/60 pb-2">
            <dt class="text-text-tertiary">Developer</dt>
            <dd class="font-mono text-text">Christophe Cornelis</dd>
          </div>
          <div class="flex justify-between border-b border-stroke-soft/60 pb-2">
            <dt class="text-text-tertiary">Platform</dt>
            <dd class="font-mono text-text">iOS — iPhone, iPad</dd>
          </div>
          <div class="flex justify-between border-b border-stroke-soft/60 pb-2">
            <dt class="text-text-tertiary">Category</dt>
            <dd class="font-mono text-text">Utilities</dd>
          </div>
          <div class="flex justify-between border-b border-stroke-soft/60 pb-2">
            <dt class="text-text-tertiary">Pricing</dt>
            <dd class="font-mono text-text">Free · Pro $9.99 lifetime</dd>
          </div>
          <div class="flex justify-between border-b border-stroke-soft/60 pb-2">
            <dt class="text-text-tertiary">Bundle ID</dt>
            <dd class="font-mono text-text">{site.bundleId}</dd>
          </div>
          <div class="flex justify-between border-b border-stroke-soft/60 pb-2">
            <dt class="text-text-tertiary">App Store URL</dt>
            <dd>
              <a class="text-accent" href={site.appStoreUrl} target="_blank" rel="noopener">
                apps.apple.com
              </a>
            </dd>
          </div>
        </dl>
      </div>

      <div>
        <h3 class="mb-2 text-base font-semibold tracking-tight text-text">
          Trademark line
        </h3>
        <p class="rounded-lg border border-stroke-soft bg-surface/60 p-5 text-[14px] text-text-secondary">
          {site.trademarkLine}
        </p>
      </div>

      <div>
        <h3 class="mb-2 text-base font-semibold tracking-tight text-text">Contact</h3>
        <p>
          For press, podcast, or interview requests:
          <a class="text-accent" href={`mailto:${site.supportEmail}`}>{site.supportEmail}</a>.
        </p>
      </div>
    </div>
  </Section>
</BaseLayout>
