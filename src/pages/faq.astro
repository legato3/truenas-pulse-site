---
import BaseLayout from "~/components/BaseLayout.astro";
import Section from "~/components/Section.astro";
import MotionReveal from "~/components/MotionReveal.astro";
import { site } from "~/data/site";

const faqs = [
  {
    q: "Is this an official iXsystems app?",
    a: "No. TrueNAS Pulse is an independent third-party application developed by Christophe Cornelis. It is not affiliated with, endorsed by, or sponsored by iXsystems. TrueNAS® is a registered trademark of iXsystems, Inc.",
  },
  {
    q: "Which TrueNAS versions are supported?",
    a: "TrueNAS SCALE only — version 24.04 and later, including 25.04, 25.10, and 26.x. CORE is not supported. The app uses WebSocket JSON-RPC as the primary transport, with REST as a compatibility fallback for older SCALE versions. Your SCALE server must have remote API access enabled.",
  },
  {
    q: "Which iOS version do I need?",
    a: "iOS 17.6 or later. The app uses Live Activities, the Dynamic Island, and Home Screen widgets — features that depend on iOS 17 surfaces.",
  },
  {
    q: "Does it work on iPad or Mac?",
    a: "Not at the moment. TrueNAS Pulse is built and submitted as iPhone-only (Targeted Device Family = iPhone). iPad and Apple Silicon Mac aren't supported in the current release. iPhone Mirroring on macOS works because that's a system feature, not an app capability.",
  },
  {
    q: "Does the app talk to anything except my own server?",
    a: "Direct by default. TrueNAS Pulse talks to the TrueNAS servers you configure and has no analytics or telemetry. If you opt in to Cloud Push Relay, it is only used to deliver alert summaries when the app is backgrounded or closed. It is off by default, configured per server, and never receives API tokens or credentials. You can also point the app at a self-hosted relay you run yourself.",
  },
  {
    q: "Does my server need to be on the public internet?",
    a: "No. The app connects over any reachable IP — same LAN, a Tailscale tailnet, a WireGuard / OpenVPN tunnel, or a reverse-proxied hostname. Most homelab users run TrueNAS Pulse over Tailscale or a private VPN and never expose the TrueNAS API publicly.",
  },
  {
    q: "Where are my API tokens stored?",
    a: "Exclusively in the iOS Keychain on your device. They are never synced to iCloud and never leave your phone. iCloud Sync (Pro) syncs your monitor configurations and server list across your own devices via your private iCloud Key-Value Store — credentials are never part of that sync.",
  },
  {
    q: "Will I get notifications when the app is closed?",
    a: "By default the app delivers device-local notifications when monitors fire while it's running. For alerts that need to reach you while the app is backgrounded or closed, you can opt in to Cloud Push Relay per server. The relay only forwards alert summaries — never API tokens or credentials. You can also self-host the relay if you'd rather not use the built-in one.",
  },
  {
    q: "How do self-signed TLS certificates work?",
    a: "By default the app does strict TLS validation. If your server uses a self-signed certificate (common in self-hosted environments), the app prompts you once to review and pin the certificate's SHA-256 fingerprint. This is opt-in per server.",
  },
  {
    q: "Can I try the app without connecting to a real server?",
    a: 'Yes. The welcome screen has a "Preview with Sample Data" option that loads the full UI with realistic read-only fixture data. All five tabs are navigable; control actions are visible but disabled.',
  },
  {
    q: "What does Pro cost? Is it a subscription?",
    a: "Pro is a one-time, lifetime purchase. No subscription, no recurring charges, no expiry. The price is set in App Store Connect and displayed in your local currency. If you've purchased Pro and reinstall, use the Restore Purchases button — it's tied to your Apple ID.",
  },
  {
    q: "Why is Pro $9.99 and not free?",
    a: "Pro funds ongoing development and keeps the app independent, ad-free, and without telemetry. The Free tier is genuinely useful — live monitoring, alerts, storage health, and one local monitor are all included without cost.",
  },
  {
    q: "Does Pro support Apple Family Sharing?",
    a: "Yes. TrueNAS Pulse Pro is configured as Family Shareable. When Family Sharing is set up on your Apple account, eligible family members can unlock Pro on their own devices without a second purchase. Use Restore Purchases after signing in.",
  },
  {
    q: "How many servers can I monitor?",
    a: "Free supports up to 2 servers. Pro raises the cap to 8 servers. Switching between servers is instant and aggregated alert views span every system you've added.",
  },
  {
    q: "How safe are the control actions?",
    a: "All state-changing actions require Control Mode — a confirmation gate with a persistent banner and 5-minute auto-expire. High-risk actions (reboot, shutdown, disk wipe, snapshot rollback) additionally require an arming toggle plus biometric authentication. Network mutations require an outage-risk acknowledgement.",
  },
  {
    q: "Is there an Android version?",
    a: "An Android version is currently being looked into — no release date yet. TrueNAS Pulse on iOS is a native SwiftUI app built around iOS-specific surfaces (Dynamic Island, Live Activities, Home Screen widgets, App Intents), so an Android build will be a separately considered native effort, not a cross-platform port.",
  },
  {
    q: "Is there a beta / TestFlight?",
    a: `Yes. You can join the TestFlight beta at ${site.testFlightUrl}. Beta builds include upcoming features ahead of the App Store release. The same Free/Pro pricing applies inside the beta — joining TestFlight doesn't unlock paid features for free.`,
    html: `Yes. You can <a href="${site.testFlightUrl}" target="_blank" rel="noopener" class="text-accent underline underline-offset-2 hover:text-accent-hover transition-colors">join the TestFlight beta here</a>. Beta builds include upcoming features ahead of the App Store release. The same Free/Pro pricing applies inside the beta — joining TestFlight doesn't unlock paid features for free.`,
  },
  {
    q: "Where do I report a bug?",
    a: "Open an issue at github.com/legato3/TrueNAS-Pulse-App, or email chris@phobos-cc.be.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<BaseLayout
  title="FAQ"
  description="Common questions about TrueNAS Pulse — which TrueNAS SCALE versions are supported, iOS requirements, privacy, notifications, Pro pricing, and Android plans."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Section
    eyebrow="Help"
    heading="Frequently asked questions"
    lede="If your question isn't here, reach us at chris@phobos-cc.be."
    width="narrow"
  >
    <div class="space-y-3">
      {
        faqs.map((item, i) => (
          <MotionReveal delay={i * 25}>
            <details
              class="card group rounded-lg border border-stroke-soft bg-surface transition-colors hover:border-stroke-strong"
            >
              <summary class="flex cursor-pointer items-center justify-between gap-3 px-5 py-4 text-[15px] font-medium text-text">
                {item.q}
                <span
                  class="text-text-tertiary transition-transform group-open:rotate-180"
                  aria-hidden="true"
                >
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path
                      d="M3 5l4 4 4-4"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </summary>
              <div class="border-t border-stroke-soft/60 px-5 pb-5 pt-4 text-sm leading-relaxed text-text-secondary">
                {item.html
                  ? <Fragment set:html={item.html} />
                  : item.a}
              </div>
            </details>
          </MotionReveal>
        ))
      }
    </div>
  </Section>
</BaseLayout>
