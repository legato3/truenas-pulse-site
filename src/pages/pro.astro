---
import BaseLayout from "~/components/BaseLayout.astro";
import Section from "~/components/Section.astro";
import TierCompare from "~/components/TierCompare.astro";
import MotionReveal from "~/components/MotionReveal.astro";
---

<BaseLayout
  title="Pro for TrueNAS Operators"
  description="TrueNAS Pulse Pro is a one-time upgrade for operators managing more TrueNAS SCALE servers, investigating incidents, using fleet view, terminal, and guarded actions."
>
  <Section
    eyebrow="One purchase. No subscription."
    heading="Pro is for deeper operator work."
    headingLevel="h1"
    lede="For people managing more servers, investigating incidents, and using advanced guarded tools. One-time purchase, no subscription."
  >
    <TierCompare />
  </Section>

  <Section eyebrow="Why Pro exists" heading="Free stays useful. Pro goes deeper." width="narrow">
    <MotionReveal>
      <div class="space-y-6 text-base leading-relaxed text-text-secondary">
        <p>
          Free is useful forever for monitoring your own TrueNAS setup: live
          health, alerts, storage visibility, jobs, widgets, and one proactive
          monitor without a time limit.
        </p>
        <p>
          Pro is a one-time upgrade for deeper history, fleet visibility, more
          servers, terminal access, and advanced guarded operator tools. It is
          optional by design — no subscription, no expiry.
        </p>
        <blockquote class="border-l-2 border-stroke-strong pl-4 text-text">
          "Pro covers ongoing development and keeps the app independent,
          ad-free, and without telemetry."
        </blockquote>
        <p>
          The Free tier is not a demo trap. Critical alerts, pool health, live
          monitoring, jobs, services view, one local monitor, the Home Screen
          widget, and the audit log viewer remain available without paying.
        </p>
        <p>
          What Pro adds is reach: more servers, fleet view, 30 days of history
          to investigate incidents, unlimited monitors, terminal access,
          lifecycle controls, and advanced guarded actions behind the same
          Control Mode model that exists in Free.
        </p>
      </div>
    </MotionReveal>
  </Section>

  <Section eyebrow="What you actually get" heading="Pro at a glance." width="narrow" tight>
    <MotionReveal>
      <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        {
          [
            "Fleet view across every server",
            "Unlimited proactive monitors",
            "30 days of historical reporting",
            "Live system log streaming",
            "Disk & VDEV management",
            "Manual ZFS snapshots",
            "Service / app / VM lifecycle",
            "Network, share, and service config",
            "Data protection editing & batch",
            "Terminal — SSH from your phone",
            "Config backup, restore, support bundle",
            "iCloud Sync · Live Activities · 8 servers",
          ].map((item) => (
            <li class="card flex items-start gap-2.5 rounded-lg border border-stroke-soft bg-surface p-4 text-sm text-text-secondary">
              <span class="mt-1 text-accent">✓</span>
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </MotionReveal>
  </Section>
</BaseLayout>
